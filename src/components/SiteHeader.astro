---
import { withBase } from '../utils/paths';

interface Props {
  current?: 'home' | 'ai-data' | 'musik' | 'blog';
}

const { current = 'home' } = Astro.props;

const navItems = [
  { href: '/beratung', label: 'AI & Data', key: 'ai-data' },
  { href: '/musik', label: 'Musik', key: 'musik' },
  { href: '/#kontakt', label: 'Kontakt', key: 'contact' },
];

const externalLinks = [
  { href: 'https://www.linkedin.com/in/raphael-fredebeul-733605140/', label: 'LinkedIn', icon: 'linkedin' },
  { href: 'https://soundcloud.com/raphael-fredebeul', label: 'SoundCloud', icon: 'soundcloud' },
];
---

<header class="site-header">
  <a class="wordmark" href={withBase('/')} aria-label="Startseite Raphael Fredebeul">
    <span class="wordmark-name">Raphael Fredebeul</span>
    <span class="wordmark-role">Data Scientist und kreative Praxis</span>
  </a>
  <nav class="nav" aria-label="Hauptnavigation">
    {navItems.map((item) => (
      <a href={withBase(item.href)} aria-current={current === item.key ? 'page' : undefined}>
        {item.label}
      </a>
    ))}
  </nav>
  <div class="header-links" aria-label="Externe Links">
    {externalLinks.map((item) => (
      <a href={item.href} target="_blank" rel="noreferrer" aria-label={item.label} title={item.label}>
        {item.icon === 'linkedin' ? (
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.94 8.5V19H3.5V8.5h3.44ZM7.16 5.26c0 1-.74 1.74-1.94 1.74A1.72 1.72 0 0 1 3.32 5.3c0-1 .76-1.76 1.92-1.76s1.88.74 1.92 1.72ZM20.68 12.58V19h-3.42v-6.02c0-1.52-.54-2.56-1.9-2.56-1.04 0-1.66.7-1.94 1.38-.1.24-.12.58-.12.92V19H9.88s.04-9.74 0-10.5h3.42v1.48c.45-.7 1.26-1.7 3.08-1.7 2.24 0 3.92 1.46 3.92 4.6Z" />
          </svg>
        ) : (
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4.37 13.44a2.06 2.06 0 0 0 2.05 2.06h11.95a1.58 1.58 0 1 0 0-3.16h-.59a4.24 4.24 0 0 0-8.13-1.66 2.75 2.75 0 0 0-1.08-.22 2.73 2.73 0 0 0-2.63 1.97 2.05 2.05 0 0 0-1.57 2.01Zm14.72 4.1c.24 0 .43.19.43.42v.34a.43.43 0 0 1-.43.43H5.74a.43.43 0 0 1-.43-.43v-.34c0-.23.19-.42.43-.42h13.35Zm-11.4 2.15c.23 0 .42.19.42.42v.35a.42.42 0 0 1-.42.42H5.74a.42.42 0 0 1-.43-.42v-.35c0-.23.19-.42.43-.42h1.95Zm3.04 0c.23 0 .42.19.42.42v.35a.42.42 0 0 1-.42.42H8.78a.42.42 0 0 1-.42-.42v-.35c0-.23.19-.42.42-.42h1.95Zm3.03 0c.24 0 .43.19.43.42v.35a.43.43 0 0 1-.43.42h-1.95a.42.42 0 0 1-.42-.42v-.35c0-.23.19-.42.42-.42h1.95Zm3.03 0c.24 0 .43.19.43.42v.35a.43.43 0 0 1-.43.42h-1.95a.42.42 0 0 1-.42-.42v-.35c0-.23.19-.42.42-.42h1.95Z" />
          </svg>
        )}
      </a>
    ))}
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0.75rem;
    z-index: 30;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) auto auto;
    gap: 1rem;
    align-items: center;
    margin-bottom: clamp(1.25rem, 3vw, 2.4rem);
    padding: 0.95rem 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: var(--panel-strong);
    box-shadow: var(--shadow-card);
    backdrop-filter: blur(20px);
  }

  .wordmark {
    display: grid;
    gap: 0.12rem;
    min-width: 0;
  }

  .wordmark-name {
    font-size: 1.02rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .wordmark-role {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .nav,
  .header-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    font-size: var(--text-sm);
    min-width: 0;
  }

  .nav {
    justify-content: center;
  }

  .header-links {
    justify-content: flex-end;
  }

  .nav a,
  .header-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.65rem;
    padding: 0.7rem 0.95rem;
    border: 1px solid transparent;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.55);
    color: var(--muted);
  }

  .nav a {
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .header-links a {
    background: transparent;
    border-color: var(--line);
    color: var(--text);
    width: 2.65rem;
    padding: 0;
  }

  .nav a[aria-current='page'] {
    border-color: var(--text);
    background: var(--text);
    color: var(--bg);
  }

  .nav a:hover,
  .header-links a:hover {
    color: var(--accent-strong);
    border-color: currentColor;
    transform: translateY(-1px);
  }

  .nav a[aria-current='page']:hover {
    color: var(--bg);
  }

  .header-links a svg {
    width: 1.1rem;
    height: 1.1rem;
    fill: currentColor;
  }

  @media (max-width: 980px) {
    .site-header {
      position: relative;
      top: 0;
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .nav {
      justify-content: flex-start;
    }

    .header-links {
      justify-content: flex-start;
    }
  }

  @media (max-width: 720px) {
    .site-header {
      padding: 0.85rem;
      margin-bottom: 1rem;
      border-radius: var(--radius-lg);
    }

    .nav {
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 0.15rem;
      scrollbar-width: none;
      justify-content: flex-start;
    }

    .nav::-webkit-scrollbar {
      display: none;
    }

    .nav a,
    .header-links a {
      white-space: nowrap;
    }

    .header-links {
      gap: 0.45rem;
    }
  }
</style>

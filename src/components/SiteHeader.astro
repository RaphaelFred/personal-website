---
import { withBase } from '../utils/paths';

interface Props {
  current?: 'home' | 'ai-data' | 'musik' | 'blog';
}

const { current = 'home' } = Astro.props;

const navItems = [
  { href: '/beratung', label: 'AI & Data', key: 'ai-data' },
  { href: '/musik', label: 'Musik', key: 'musik' },
  { href: '/#kontakt', label: 'Kontakt', key: 'contact' },
];

const externalLinks = [
  { href: 'https://www.linkedin.com/in/raphael-fredebeul-733605140/', label: 'LinkedIn' },
  { href: 'https://soundcloud.com/raphael-fredebeul', label: 'SoundCloud' },
];
---

<header class="site-header">
  <a class="wordmark" href={withBase('/')} aria-label="Startseite Raphael Fredebeul">Raphael Fredebeul</a>
  <nav class="nav" aria-label="Hauptnavigation">
    {navItems.map((item) => (
      <a href={withBase(item.href)} aria-current={current === item.key ? 'page' : undefined}>{item.label}</a>
    ))}
  </nav>
  <div class="header-links" aria-label="Externe Links">
    {externalLinks.map((item) => (
      <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
    ))}
  </div>
</header>

<style>
  .site-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.5rem;
    align-items: center;
    padding: 0.85rem 0 1rem;
    border-top: 1px solid var(--line);
  }

  .wordmark {
    font-size: var(--text-md);
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .nav,
  .header-links {
    display: flex;
    gap: 1.25rem;
    color: var(--muted);
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
  }

  .nav {
    text-transform: uppercase;
  }

  .header-links {
    justify-content: flex-end;
    text-transform: none;
    letter-spacing: 0;
  }

  .nav a[aria-current='page'] {
    color: var(--text);
  }

  .nav a:hover,
  .header-links a:hover {
    color: var(--accent-strong);
  }

  @media (max-width: 980px) {
    .site-header {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .header-links {
      justify-content: flex-start;
    }
  }

  @media (max-width: 720px) {
    .nav,
    .header-links {
      flex-wrap: wrap;
    }
  }
</style>

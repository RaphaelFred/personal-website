---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import SiteHeader from '../../components/SiteHeader.astro';
import { withBase } from '../../utils/paths';

const blogImages = {
  'building-clarity-from-complexity': '/blog/ai-adoption-organisationen.jpg',
  'fruehe-produktsignale-erkennen': '/blog/user-innovation-mit-ki.jpg',
  'experimente-richtig-framen': '/blog/use-case-identifikation-ki.jpg',
  'forecasting-unter-unsicherheit': '/blog/strategische-datenanalyse-innovation.jpg',
};

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const postHeroImage = withBase(blogImages[post.slug] ?? '/images/hero-illustration.jpg');
---

<Layout title={`${post.data.title} | AI & Data`} description={post.data.description}>
  <main class="post-page" id="main-content">
    <SiteHeader current="ai-data" />

    <header class="post-hero" style={`--post-hero-image: url('${postHeroImage}')`}>
      <div class="post-header">
        <p class="kicker">AI & Data</p>
        <h1>{post.data.title}</h1>
      </div>
    </header>

    <section class="post-intro">
      <div class="post-intro-inner">
        <p class="post-date">
          {post.data.publishDate.toLocaleDateString('de-DE', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </p>
        <div class="abstract-block">
          <a class="back-link" href={withBase('/beratung#artikel')}>Zurueck zu AI & Data</a>
          <p class="intro-label">Abstract</p>
          <p class="lead">{post.data.description}</p>
        </div>
      </div>
    </section>

    <article class="post-body">
      <Content />
      <div class="article-thesis">
        <p class="intro-label">Kernthese</p>
        <p class="thesis-text">{post.data.coreThesis}</p>
      </div>
    </article>
  </main>
</Layout>

<style>
  .post-page {
    width: var(--container-narrow);
    margin: 0 auto;
    padding: 1.15rem 0 4rem;
  }

  .post-hero,
  .post-intro,
  .post-body {
    border-top: 1px solid var(--line);
  }

  .post-hero,
  .post-intro,
  .post-body {
    padding: 2rem 0;
  }

  .post-hero {
    position: relative;
    overflow: hidden;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    min-height: var(--hero-min-height);
    display: flex;
    align-items: start;
    padding: clamp(2.2rem, 5vw, 3rem) 0 2rem;
    border-bottom: 1px solid var(--line);
  }

  .post-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(244, 246, 243, 0.04), rgba(244, 246, 243, 0.12)),
      var(--post-hero-image) center / cover no-repeat;
    opacity: 1;
    pointer-events: none;
    z-index: 0;
    filter: saturate(0.66) contrast(0.92);
  }

  .post-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(244, 246, 243, 0.9) 0%, rgba(244, 246, 243, 0.62) 38%, rgba(244, 246, 243, 0.2) 100%),
      linear-gradient(180deg, rgba(244, 246, 243, 0.24) 0%, rgba(244, 246, 243, 0.08) 36%, rgba(244, 246, 243, 0.26) 100%);
    pointer-events: none;
    z-index: 0;
  }

  .post-header {
    width: min(1120px, calc(100vw - 3rem));
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .back-link,
  .lead,
  .thesis-text,
  .post-body :global(p),
  .post-body :global(li),
  .post-body :global(blockquote) {
    color: var(--muted);
    line-height: 1.78;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    min-height: 2.8rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(23, 25, 20, 0.18);
    border-radius: var(--radius-pill);
    background: rgba(23, 25, 20, 0.9);
    color: var(--bg);
    box-shadow: var(--shadow-card);
  }

  .back-link:hover {
    color: var(--bg);
    background: var(--accent-strong);
    border-color: var(--accent-strong);
    transform: translateY(-1px);
  }

  .post-body :global(a:hover) {
    color: var(--accent-strong);
    border-color: currentColor;
    transform: translateY(-1px);
  }

  .kicker,
  .intro-label,
  .post-date {
    margin: 0;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent-strong);
  }

  h1,
  p {
    margin-top: 0;
  }

  h1 {
    margin: 0.5rem 0 1rem;
    max-width: 11ch;
    font-size: clamp(3.3rem, 8.5vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.055em;
  }

  .lead {
    margin: 0.8rem 0 0;
    max-width: 38rem;
    font-size: clamp(1.08rem, 1.8vw, 1.26rem);
  }

  .post-intro-inner {
    display: grid;
    gap: 0.9rem;
    width: min(860px, calc(100vw - 3rem));
    margin: 0 auto;
    padding: 0.15rem 0.35rem 0;
  }

  .abstract-block {
    display: grid;
    gap: 0.8rem;
    padding: 1.1rem 1.15rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--panel);
    box-shadow: var(--shadow-card);
  }

  .post-date {
    margin-top: 0.2rem;
  }

  .thesis-text {
    margin: -0.1rem 0 0;
    padding: 1rem 1.05rem;
    border-left: 3px solid var(--accent-warm);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    background: rgba(255, 255, 255, 0.62);
    font-size: clamp(1.02rem, 1.5vw, 1.16rem);
  }

  .post-body {
    padding-inline: 0.35rem;
  }

  .article-thesis {
    margin-top: 2.4rem;
  }

  .post-body :global(p:first-child) {
    display: none;
  }

  .post-body :global(h2) {
    margin: 2.4rem 0 0.85rem;
    font-size: var(--title-md);
    line-height: 1.14;
    letter-spacing: -0.02em;
  }

  .post-body :global(h3) {
    margin: 1.8rem 0 0.65rem;
    font-size: 1.18rem;
    line-height: 1.2;
  }

  .post-body :global(a) {
    color: var(--accent-strong);
    text-decoration: underline;
    text-decoration-color: rgba(140, 61, 34, 0.28);
    text-underline-offset: 0.18em;
  }

  .post-body :global(img) {
    display: block;
    width: 100%;
    margin: 1.8rem 0 2rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.82);
    box-shadow: var(--shadow-card);
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.2rem;
  }

  .post-body :global(blockquote) {
    margin: 1.8rem 0;
    padding: 1rem 1.15rem;
    border-left: 3px solid var(--accent-warm);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    background: rgba(255, 255, 255, 0.62);
  }

  @media (max-width: 720px) {
    .post-page {
      padding-top: 0.85rem;
    }

    .post-hero,
    .post-intro,
    .post-body {
      padding: 1.6rem 0;
    }

    .post-hero {
      min-height: var(--hero-min-height-mobile);
      padding-top: 1.6rem;
    }

    .post-hero::after {
      background: linear-gradient(180deg, rgba(244, 246, 243, 0.58) 0%, rgba(244, 246, 243, 0.24) 42%, rgba(244, 246, 243, 0.18) 100%);
    }

    .post-header {
      width: min(1120px, calc(100vw - 1.5rem));
    }

    .post-intro-inner {
      width: min(860px, calc(100vw - 1.5rem));
      padding-inline: 0;
    }

    .post-body {
      padding-inline: 0;
    }

  }
</style>

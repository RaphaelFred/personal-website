---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import SiteHeader from '../components/SiteHeader.astro';
import { withBase } from '../utils/paths';

const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const blogImages = {
  'building-clarity-from-complexity': {
    src: '/blog/ai-adoption-organisationen.jpg',
    alt: 'Abstrakte Szene zu AI Adoption in Organisationen',
  },
  'fruehe-produktsignale-erkennen': {
    src: '/blog/user-innovation-mit-ki.jpg',
    alt: 'Abstrakte Visualisierung zu User Innovation mit KI',
  },
  'experimente-richtig-framen': {
    src: '/blog/use-case-identifikation-ki.jpg',
    alt: 'Abstrakte Visualisierung zur Identifikation von KI-Use-Cases',
  },
  'forecasting-unter-unsicherheit': {
    src: '/blog/strategische-datenanalyse-innovation.jpg',
    alt: 'Abstrakte Visualisierung zu strategischer Datenanalyse und Unsicherheit',
  },
};

const workAreas = [
  {
    label: 'AI & Data',
    detail: 'Forecasting, Produktanalyse, Experimentdesign und die Uebersetzung von Daten in belastbare Entscheidungen.',
    href: '/beratung',
    image: '/graphics/ai-data-panel.svg',
    alt: 'Abstrakte Grafik fuer AI und Datenarbeit',
  },
  {
    label: 'Kreativität',
    detail: 'Ein eigener Raum fuer Musik, Produktion, Rhythmus, Klang und weitere Formen kreativer Praxis.',
    href: '/kreativitaet',
    image: '/graphics/music-panel.svg',
    alt: 'Abstrakte Grafik fuer Musik und kreative Praxis',
  },
  {
    label: 'Schreiben',
    detail: 'Texte ueber Unsicherheit, Struktur, kreative Arbeit und die Frage, wie man gute analytische Arbeit lesbar macht.',
    href: '/blog',
    image: '/graphics/blog-panel.svg',
    alt: 'Abstrakte Grafik fuer Texte und Notizen',
  },
];

const aboutPoints = [
  'AI- und Datenarbeit fuer Produkt, Innovation und Entscheidungsfindung.',
  'Kreative Praxis zwischen Musik, Produktion, Rhythmus und Klang.',
  'Texte ueber Unsicherheit, Struktur, kreative Arbeit und analytisches Denken.',
];

const externalLinks = [
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/raphael-fredebeul-733605140/',
  },
  {
    label: 'SoundCloud',
    href: 'https://soundcloud.com/raphael-fredebeul',
  },
];

const contactMailto =
  'mailto:?subject=Anfrage%20zu%20AI%20%26%20Data&body=Hallo%20Raphael,%0A%0Aich%20interessiere%20mich%20fuer%20deine%20Arbeit%20im%20Bereich%20AI%20%26%20Data.%0A%0AViele%20Gruesse';

const contactDestinations = [
  { label: 'AI & Data', href: '/beratung', icon: 'grid' },
  { label: 'Kreativität', href: '/kreativitaet', icon: 'wave' },
  { label: 'Texte', href: '/blog', icon: 'pen' },
  { label: 'E-Mail', href: contactMailto, icon: 'mail' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/raphael-fredebeul-733605140/', icon: 'linkedin' },
  { label: 'SoundCloud', href: 'https://soundcloud.com/raphael-fredebeul', icon: 'soundcloud' },
];
---

<Layout
  title="Raphael Fredebeul | Data Scientist"
  description="Persoenliche Website von Raphael Fredebeul mit Fokus auf AI & Data, Innovation, Kreativitaet und Consulting."
>
  <main class="page" id="main-content">
    <SiteHeader current="home" />

    <section class="intro-section" aria-label="Einleitung">
      <div class="intro-main">
        <h1>KI. <br>
          Innovation. <br>
          Kreativität.</h1>
        <p class="intro-text">
          
        </p>
      </div>
    </section>

    <section class="list-section" aria-label="Bereiche">
      <div class="about-block">
        <p class="section-label">Meine Mission</p>
        <p class="about-text">
          Ich arbeite an der Schnittstelle von Künstlicher Intelligenz, Innovation und Kreativität.
          Mein Fokus liegt darauf, technologische Entwicklungen nicht nur zu verstehen,
          sondern in klare Strategien, neue Produkte, bessere Prozesse und kreative Möglichkeiten zu übersetzen.
          Dabei ist mir wichtig nicht nur die Perspektive der Technologie zu beachten, sondern immer auch den Menschen
          im Blick zu haben.
        </p>
      </div>

      <div class="section-grid">
        <div class="section-intro">
          <p class="section-label">Bereiche</p>
          <h2>Woran ich arbeite.</h2>
        </div>

        <div class="stack-list">
          {aboutPoints.map((item) => (
            <div class="stack-item">
              <h3 class="stack-detail">{item}</h3>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="list-section" aria-label="Texte">
      <div class="article-section-head">
        <p class="section-label">Texte</p>
        <h2>Aktuelle Notizen und Artikel.</h2>
      </div>

      <div class="article-grid">
        {blogPosts.map((post) => (
          <article class="article-card">
            <a class="article-image-link" href={withBase(`/blog/${post.slug}`)}>
              <img
                src={withBase(blogImages[post.slug]?.src ?? '/graphics/blog-panel.svg')}
                alt={blogImages[post.slug]?.alt ?? post.data.title}
                loading="lazy"
              />
            </a>
            <h3>
              <a href={withBase(`/blog/${post.slug}`)}>{post.data.title}</a>
            </h3>
            <p class="article-summary">{post.data.description}</p>
            <a class="article-link" href={withBase(`/blog/${post.slug}`)}>Read More →</a>
          </article>
        ))}
      </div>
    </section>

    <section class="visual-work-section" aria-label="Arbeitsbereiche">
      <div class="visual-work-head">
        <p class="section-label">Bereiche</p>
        <h2>AI & Data, Kreativität und Texte.</h2>
      </div>

      <div class="visual-work-grid">
        {workAreas.map((item) => (
          <article class="visual-work-card">
            <a href={withBase(item.href)}>
              <img src={withBase(item.image)} alt={item.alt} loading="lazy" />
              <h3>{item.label}</h3>
              <p>{item.detail}</p>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="contact-showcase" id="kontakt" aria-label="Kontakt">
      <div class="contact-hero">
        <div class="contact-card">
          <h2>Schreib mir gern.</h2>
          <p class="contact-copy">
            Trag hier deine E-Mail ein und oeffne direkt eine vorbereitete Nachricht fuer AI, Daten, Produktfragen und Zusammenarbeit.
          </p>

          <form class="contact-form" id="contact-form">
            <label class="sr-only" for="contact-email">E-Mail-Adresse</label>
            <input
              id="contact-email"
              name="email"
              type="email"
              placeholder="E-Mail-Adresse"
              autocomplete="email"
              required
            />
            <button type="submit">Kontakt</button>
          </form>
        </div>
      </div>

      <div class="contact-icons" aria-label="Bereiche und Profile">
        {contactDestinations.map((item) => (
          <a
            class="icon-tile"
            href={item.href}
            target={item.href.startsWith('http') ? '_blank' : undefined}
            rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
            aria-label={item.label}
            title={item.label}
          >
            {item.icon === 'grid' ? (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 4h7v7H4V4Zm9 0h7v7h-7V4ZM4 13h7v7H4v-7Zm9 0h7v7h-7v-7Z" />
              </svg>
            ) : item.icon === 'wave' ? (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M3 12c2.4 0 2.4-6 4.8-6s2.4 12 4.8 12S15 9 17.4 9 19.8 15 22 15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            ) : item.icon === 'pen' ? (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m4 16.5 9.9-9.9 3.5 3.5-9.9 9.9L4 20l.5-3.5ZM14.9 5.6l1.7-1.7a1.9 1.9 0 0 1 2.7 0l1 1a1.9 1.9 0 0 1 0 2.7l-1.7 1.7-3.7-3.7Z" />
              </svg>
            ) : item.icon === 'mail' ? (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 6h16v12H4V6Zm0 1.2 8 6 8-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            ) : item.icon === 'linkedin' ? (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6.94 8.5V19H3.5V8.5h3.44ZM7.16 5.26c0 1-.74 1.74-1.94 1.74A1.72 1.72 0 0 1 3.32 5.3c0-1 .76-1.76 1.92-1.76s1.88.74 1.92 1.72ZM20.68 12.58V19h-3.42v-6.02c0-1.52-.54-2.56-1.9-2.56-1.04 0-1.66.7-1.94 1.38-.1.24-.12.58-.12.92V19H9.88s.04-9.74 0-10.5h3.42v1.48c.45-.7 1.26-1.7 3.08-1.7 2.24 0 3.92 1.46 3.92 4.6Z" />
              </svg>
            ) : (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4.37 13.44a2.06 2.06 0 0 0 2.05 2.06h11.95a1.58 1.58 0 1 0 0-3.16h-.59a4.24 4.24 0 0 0-8.13-1.66 2.75 2.75 0 0 0-1.08-.22 2.73 2.73 0 0 0-2.63 1.97 2.05 2.05 0 0 0-1.57 2.01Zm14.72 4.1c.24 0 .43.19.43.42v.34a.43.43 0 0 1-.43.43H5.74a.43.43 0 0 1-.43-.43v-.34c0-.23.19-.42.43-.42h13.35Zm-11.4 2.15c.23 0 .42.19.42.42v.35a.42.42 0 0 1-.42.42H5.74a.42.42 0 0 1-.43-.42v-.35c0-.23.19-.42.43-.42h1.95Zm3.04 0c.23 0 .42.19.42.42v.35a.42.42 0 0 1-.42.42H8.78a.42.42 0 0 1-.42-.42v-.35c0-.23.19-.42.42-.42h1.95Zm3.03 0c.24 0 .43.19.43.42v.35a.43.43 0 0 1-.43.42h-1.95a.42.42 0 0 1-.42-.42v-.35c0-.23.19-.42.42-.42h1.95Zm3.03 0c.24 0 .43.19.43.42v.35a.43.43 0 0 1-.43.42h-1.95a.42.42 0 0 1-.42-.42v-.35c0-.23.19-.42.42-.42h1.95Z" />
              </svg>
            )}
          </a>
        ))}
      </div>
    </section>
  </main>

  <script>
    const contactForm = document.querySelector('#contact-form');

    contactForm?.addEventListener('submit', (event) => {
      event.preventDefault();

      const form = event.currentTarget;
      const emailInput = form.querySelector('#contact-email');

      if (!(emailInput instanceof HTMLInputElement) || !emailInput.value.trim()) {
        return;
      }

      const email = emailInput.value.trim();
      const subject = encodeURIComponent('Anfrage zu AI & Data');
      const body = encodeURIComponent(
        `Hallo Raphael,\n\nich interessiere mich fuer deine Arbeit im Bereich AI & Data.\n\nMeine E-Mail-Adresse: ${email}\n\nViele Gruesse`
      );

      window.location.href = `mailto:?subject=${subject}&body=${body}`;
    });
  </script>
</Layout>

<style>
  .page {
    width: min(1120px, calc(100vw - 3rem));
    margin: 0 auto;
    padding: 1rem 0 4rem;
  }

  .intro-section,
  .list-section,
  .visual-work-section,
  .contact-showcase {
    border-top: 1px solid var(--line);
  }

  .intro-section {
    position: relative;
    overflow: hidden;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    min-height: 34rem;
    display: flex;
    align-items: start;
    padding: clamp(2.2rem, 5vw, 3rem) 0 2rem;
    border-bottom: 1px solid var(--line);
  }

  .list-section {
    padding: 4.5rem 0;
  }

  .intro-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(244, 246, 243, 0.04), rgba(244, 246, 243, 0.12)),
      url('/images/hero-illustration.jpg') center / cover no-repeat;
    opacity: 1;
    pointer-events: none;
    z-index: 0;
    filter: saturate(0.66) contrast(0.92);
  }

  .intro-section::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(244, 246, 243, 0.74) 0%, rgba(244, 246, 243, 0.34) 34%, rgba(244, 246, 243, 0.08) 100%),
      linear-gradient(180deg, rgba(244, 246, 243, 0.1) 0%, rgba(244, 246, 243, 0.02) 36%, rgba(244, 246, 243, 0.18) 100%);
    pointer-events: none;
    z-index: 0;
  }

  .section-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.9fr);
    gap: clamp(2rem, 5vw, 5rem);
  }

  .about-block {
    width: 100%;
    max-width: none;
    margin-bottom: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--line);
  }

  .intro-main {
    max-width: 40rem;
    width: min(1120px, calc(100vw - 3rem));
    margin: 0 auto;
    position: relative;
    z-index: 1;
    padding-top: 0.2rem;
  }

  .section-label,
  .stack-label {
    margin: 0;
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-strong);
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin: 0;
    max-width: 11ch;
    font-size: clamp(3.3rem, 8.5vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.055em;
  }

  h2 {
    margin: 0.3rem 0 0;
    max-width: 12ch;
    font-size: clamp(1.9rem, 3.3vw, 3rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
  }

  h3 {
    margin: 0;
    font-size: clamp(1.25rem, 1.9vw, 1.55rem);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .intro-text,
  .stack-detail,
  .about-text,
  .about-list li {
    color: var(--muted);
    line-height: 1.72;
  }

  .intro-text {
    margin: 1.45rem 0 0;
    max-width: 34rem;
    font-size: clamp(1.08rem, 1.8vw, 1.26rem);
  }

  .about-text {
    margin: 0.9rem 0 0;
    max-width: 58rem;
    font-size: clamp(1.35rem, 2.6vw, 2rem);
    line-height: 1.55;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .about-list {
    margin-top: 2.4rem;
    max-width: 54rem;
  }

  .about-list h2 {
    max-width: none;
    font-size: clamp(1.5rem, 2.2vw, 2rem);
  }

  .about-list ul {
    margin: 1rem 0 0;
    padding-left: 1.2rem;
  }

  .about-list li + li {
    margin-top: 0.7rem;
  }

  .stack-list {
    display: grid;
    gap: 0;
  }

  .stack-item:hover h3 a,
  .stack-item:hover .stack-label {
    color: var(--accent-strong);
  }

  .section-intro {
    max-width: 22rem;
  }

  .stack-item {
    display: block;
    padding: 1rem 0 1.1rem;
    border-top: 1px solid var(--line);
  }

  .stack-item:first-child {
    border-top: none;
    padding-top: 0;
  }

  .stack-detail {
    margin: 0.55rem 0 0;
    max-width: 38rem;
    font-size: 1rem;
  }

  .list-section[aria-label='Bereiche'] .stack-list .stack-detail {
    margin-top: 0;
    max-width: 24rem;
    font-size: clamp(1.25rem, 1.9vw, 1.55rem);
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .article-item h3 {
    margin-top: 0.3rem;
    max-width: 24rem;
  }

  .article-item h3 a {
    color: var(--text);
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2.25rem;
  }

  .article-section-head {
    margin-bottom: 2rem;
  }

  .article-section-head h2 {
    max-width: none;
  }

  .article-card {
    display: block;
  }

  .article-image-link {
    display: block;
    color: var(--text);
  }

  .article-card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.72);
  }

  .article-card h3 {
    margin-top: 1rem;
    max-width: none;
  }

  .article-card h3 a,
  .article-link {
    color: var(--text);
  }

  .article-summary {
    margin: 0.7rem 0 0;
    color: var(--muted);
    line-height: 1.68;
    font-size: 1rem;
  }

  .article-link {
    display: inline-flex;
    align-items: center;
    margin-top: 1rem;
  }

  .article-card:hover h3 a,
  .article-card:hover .article-link {
    color: var(--accent-strong);
  }

  .contact-showcase {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    padding: 4.5rem 0 0;
  }

  .visual-work-section {
    padding: 4.5rem 0;
  }

  .visual-work-head {
    margin-bottom: 2rem;
  }

  .visual-work-head h2 {
    max-width: none;
  }

  .visual-work-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2.25rem;
  }

  .visual-work-card a {
    display: block;
    color: var(--text);
  }

  .visual-work-card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.7);
  }

  .visual-work-card h3 {
    margin-top: 1rem;
  }

  .visual-work-card p {
    margin: 0.7rem 0 0;
    color: var(--muted);
    line-height: 1.68;
    font-size: 1rem;
  }

  .contact-hero {
    position: relative;
    overflow: hidden;
    min-height: 34rem;
    display: grid;
    place-items: center;
    padding: 2rem;
    background:
      linear-gradient(180deg, rgba(244, 246, 243, 0.18), rgba(244, 246, 243, 0.24)),
      url('/images/contact-illustration.jpg') center / cover no-repeat;
  }

  .contact-card {
    width: min(100%, 46rem);
    padding: clamp(2rem, 5vw, 4rem);
    background: rgba(248, 249, 246, 0.93);
    border: 1px solid rgba(23, 25, 20, 0.08);
    box-shadow: 0 20px 50px rgba(23, 25, 20, 0.08);
    text-align: center;
  }

  .contact-card h2 {
    margin-left: auto;
    margin-right: auto;
    max-width: 13ch;
  }

  .contact-copy {
    margin: 1rem auto 0;
    max-width: 30rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .contact-form {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .contact-form input {
    width: min(100%, 22rem);
    min-height: 3.7rem;
    padding: 0 1rem;
    border: 1px solid rgba(23, 25, 20, 0.12);
    background: rgba(255, 255, 255, 0.94);
  }

  .contact-form button {
    min-height: 3.7rem;
    padding: 0 1.5rem;
    border: 1px solid var(--text);
    background: var(--text);
    color: #fff;
    cursor: pointer;
  }

  .contact-form button:hover {
    background: var(--accent-strong);
    border-color: var(--accent-strong);
  }

  .contact-icons {
    width: min(1120px, calc(100vw - 3rem));
    margin-left: auto;
    margin-right: auto;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.35rem;
    padding: 1.35rem 0 0;
    border-top: 1px solid var(--line);
  }

  .icon-tile {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--text);
  }

  .icon-tile svg {
    width: 1.15rem;
    height: 1.15rem;
    fill: currentColor;
  }

  .icon-tile:hover {
    color: var(--accent-strong);
    border-color: currentColor;
    transform: translateY(-1px);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 900px) {
    .section-grid {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }

    .intro-section {
      min-height: auto;
      align-items: start;
    }

    .intro-section::before {
      opacity: 1;
    }

    .intro-section::after {
      background: linear-gradient(180deg, rgba(244, 246, 243, 0.58) 0%, rgba(244, 246, 243, 0.24) 42%, rgba(244, 246, 243, 0.18) 100%);
    }

    .section-intro,
    .intro-main {
      max-width: none;
    }

    .visual-work-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .article-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .contact-form {
      flex-direction: column;
      align-items: stretch;
    }

    .contact-form input,
    .contact-form button {
      width: 100%;
    }
  }

  @media (max-width: 720px) {
    .page {
      width: min(1120px, calc(100vw - 1.5rem));
      padding-top: 0.6rem;
      padding-bottom: 3rem;
    }

    .intro-main {
      width: min(1120px, calc(100vw - 1.5rem));
    }


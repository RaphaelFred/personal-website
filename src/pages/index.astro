---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import SiteHeader from '../components/SiteHeader.astro';

const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 4);

const currentFocus = [
  'AI & Data fuer Produktfragen, Innovation und analytische Strategie',
  'Arbeit an Themen rund um Innovation, Struktur und bessere Entscheidungen',
  'Musik als eigenstaendige kreative Praxis',
  'Artikel innerhalb von AI & Data zu Data Science, kreative Prozesse und Arbeitsweisen',
];

const background = [
  'Data Scientist mit Interesse an Schnittstellen zwischen Analyse, Strategie und Kreativitaet',
  'Fokus auf Fragen, bei denen Daten nicht nur messen, sondern Orientierung geben sollen',
  'Besonderes Interesse an Projekten mit offenem Denkraum und echter Entscheidungsrelevanz',
];

const links = [
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/raphael-fredebeul-733605140/',
  },
  {
    label: 'SoundCloud',
    href: 'https://soundcloud.com/raphael-fredebeul',
  },
];

const contactMailto =
  'mailto:?subject=Anfrage%20zu%20AI%20%26%20Data&body=Hallo%20Raphael,%0A%0Aich%20interessiere%20mich%20fuer%20deine%20Arbeit%20im%20Bereich%20AI%20%26%20Data.%0A%0AViele%20Gruesse';
---

<Layout
  title="Raphael Fredebeul | Data Scientist"
  description="Persoenliche Website von Raphael Fredebeul mit Fokus auf AI & Data, Innovation, Kreativitaet und Consulting."
>
  <main class="page" id="main-content">
    <SiteHeader current="home" />

    <section class="intro">
      <p class="kicker">Data Scientist</p>
      <h1>Daten, Strategie und kreative Praxis.</h1>
      <p class="lead">
        Ich arbeite an Themen rund um Data Science, Innovation und analytische Orientierung. Diese
        Website ist als offene Uebersicht ueber meine Arbeit, meine Musik und meine Texte gedacht.
      </p>
    </section>

    <section class="overview">
      <div class="section-copy">
        <p class="kicker">Aktuell</p>
        <h2>Woran ich gerade arbeite.</h2>
      </div>
      <div class="list-block">
        {currentFocus.map((item) => (
          <p>{item}</p>
        ))}
      </div>
    </section>

    <section class="blog-preview">
      <div class="blog-preview-head">
        <div class="section-copy">
          <p class="kicker">AI & Data Artikel</p>
          <h2>Notizen und Artikel aus meiner analytischen Arbeit.</h2>
        </div>
        <a class="text-link" href="/beratung#artikel">Alle Artikel</a>
      </div>

      <div class="posts-list">
        {blogPosts.map((post) => (
          <article class="post-row">
            <p class="post-date">{post.data.publishDate.toLocaleDateString('de-DE', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}</p>
            <div class="post-body">
              <h3>
                <a href={`/blog/${post.slug}`}>{post.data.title}</a>
              </h3>
              <p>{post.data.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="overview">
      <div class="section-copy">
        <p class="kicker">Hintergrund</p>
        <h2>Wie ich meine Arbeit einordne.</h2>
      </div>
      <div class="list-block">
        {background.map((item) => (
          <p>{item}</p>
        ))}
      </div>
    </section>

    <section class="feature-split">
      <div class="section-copy">
        <p class="kicker">AI & Data</p>
        <h2>Analytische Klarheit fuer Produkt, Innovation und Entscheidungen.</h2>
        <p class="body-copy">
          Wenn du an einem Projekt arbeitest, bei dem Daten, Modelle oder AI in eine belastbare
          Richtung uebersetzt werden sollen, ist diese Seite der richtige Einstieg.
        </p>
        <a class="text-link" href="/beratung">AI & Data ansehen</a>
      </div>

      <div class="section-copy">
        <p class="kicker">Musik</p>
        <h2>Ein eigener Bereich fuer Klang, Rhythmus und kreative Arbeit.</h2>
        <p class="body-copy">
          Neben meiner analytischen Arbeit ist Musik ein eigenstaendiger Teil meiner Praxis und
          meines Denkens.
        </p>
        <a class="text-link" href="/musik">Musikbereich ansehen</a>
      </div>
    </section>

    <section class="cv-section">
      <div class="section-copy">
        <p class="kicker">Kurzprofil</p>
        <h2>Ein kompakter Lebenslauf auf einen Blick.</h2>
      </div>

      <div class="cv-list">
        <article class="cv-row">
          <p class="cv-label">Profil</p>
          <div>
            <h3>Data Scientist</h3>
            <p>Fokus auf Data Science, Innovation, Produktfragen und analytische Strategie.</p>
          </div>
        </article>
        <article class="cv-row">
          <p class="cv-label">Schwerpunkte</p>
          <div>
            <h3>Analyse, Modelle und Entscheidungsunterstuetzung</h3>
            <p>Machine Learning, Forecasting, Produktanalyse, Experimentdesign und Data Storytelling.</p>
          </div>
        </article>
        <article class="cv-row">
          <p class="cv-label">Interessen</p>
          <div>
            <h3>Struktur, Innovation und kreative Praxis</h3>
            <p>Besonderes Interesse an Projekten mit offenem Denkraum, Interpretationsspielraum und klarer Relevanz.</p>
          </div>
        </article>
      </div>
    </section>

    <section class="contact" id="kontakt">
      <p class="kicker">Kontakt</p>
      <div class="contact-grid">
        <a class="contact-primary" href={contactMailto}>
          AI & Data per E-Mail anfragen
        </a>
        <a href="https://soundcloud.com/raphael-fredebeul" target="_blank" rel="noreferrer">SoundCloud</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page {
    width: var(--container);
    margin: 0 auto;
    padding: 1rem 0 4rem;
  }

  .intro,
  .overview,
  .feature-split,
  .blog-preview,
  .cv-section,
  .contact {
    border-top: 1px solid var(--line);
  }
  .text-link:hover,
  .post-body a:hover,
  .contact-grid a:hover {
    color: var(--accent-strong);
  }

  .intro,
  .overview,
  .blog-preview,
  .cv-section,
  .contact {
    padding: 2rem 0;
  }

  .feature-split {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem;
    padding: 2rem 0;
  }

  .kicker,
  .post-date,
  .cv-label {
    margin: 0;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent-strong);
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin: 0.55rem 0 1rem;
    max-width: 10ch;
    font-size: var(--title-xl);
    line-height: 0.96;
    letter-spacing: -0.045em;
    font-weight: 700;
  }

  h2 {
    margin: 0.6rem 0 0;
    max-width: 15ch;
    font-size: var(--title-lg);
    line-height: 1.02;
    letter-spacing: -0.035em;
  }

  h3 {
    margin: 0;
    font-size: var(--title-md);
    line-height: 1.14;
    letter-spacing: -0.02em;
  }

  .lead,
  .body-copy,
  .list-block p,
  .post-body p,
  .cv-row p,
  .contact-grid a,
  .text-link {
    color: var(--muted);
    line-height: 1.65;
    font-size: var(--text-md);
  }

  .lead {
    max-width: 38rem;
    font-size: var(--text-lg);
  }

  .section-copy {
    display: grid;
    gap: 0.2rem;
  }

  .list-block {
    display: grid;
    border-top: 1px solid var(--line);
    margin-top: 1.25rem;
  }

  .list-block p {
    margin: 0;
    padding: 1rem 0;
    border-bottom: 1px solid var(--line);
  }

  .text-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--text);
  }

  .blog-preview-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .posts-list {
    display: grid;
    border-top: 1px solid var(--line);
    margin-top: 1.25rem;
  }

  .post-row {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 1.5rem;
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--line);
  }

  .post-body {
    min-width: 0;
  }

  .post-body a {
    color: var(--text);
  }

  .post-body p {
    margin: 0.45rem 0 0;
    max-width: 42rem;
  }

  .cv-list {
    display: grid;
    border-top: 1px solid var(--line);
    margin-top: 1.25rem;
  }

  .cv-row {
    display: grid;
    grid-template-columns: 160px minmax(0, 1fr);
    gap: 1.5rem;
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--line);
  }

  .cv-row p {
    margin: 0.45rem 0 0;
    max-width: 44ch;
  }

  .contact-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .contact-primary {
    color: var(--text);
    font-weight: 600;
  }

  @media (max-width: 980px) {
    .feature-split,
    .post-row,
    .cv-row {
      grid-template-columns: 1fr;
    }
  }
  
  @media (max-width: 720px) {
    h1,
    h2 {
      max-width: 100%;
    }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import SiteHeader from '../components/SiteHeader.astro';
import { withBase } from '../utils/paths';

const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 4);

const currentFocus = [
  {
    title: 'AI & Data fuer Produktfragen',
    detail: 'Analysen, Modelle und Signale in klare Entscheidungen und realistische Prioritaeten uebersetzen.',
  },
  {
    title: 'Innovation mit Struktur',
    detail: 'Unscharfe Fragen so aufbauen, dass Teams daraus belastbare Hypothesen und naechste Schritte machen koennen.',
  },
  {
    title: 'Musik als Gegenpol',
    detail: 'Klang, Rhythmus und Produktion als eigenstaendige kreative Praxis mit eigener Sprache und Energie.',
  },
  {
    title: 'Texte aus der Praxis',
    detail: 'Artikel ueber Forecasting, Experimentdesign, Unsicherheit und kreative Arbeitsweisen innerhalb von AI & Data.',
  },
];

const principles = [
  {
    title: 'Praezise Fragen vor schnellen Antworten',
    detail: 'Gute analytische Arbeit beginnt fuer mich mit sauber gerahmten Problemen, nicht mit vorschneller Komplexitaet.',
  },
  {
    title: 'Entscheidungsrelevanz statt Datendekoration',
    detail: 'Daten sollen nicht nur messen, sondern Orientierung geben, Spannungen sichtbar machen und Optionen klarer machen.',
  },
  {
    title: 'Klar kommuniziert und anschlussfaehig',
    detail: 'Insights muessen so aufbereitet sein, dass Produkt, Strategie und Stakeholder damit wirklich weiterarbeiten koennen.',
  },
];

const profileHighlights = [
  {
    label: 'Profil',
    title: 'Data Scientist an der Schnittstelle von Analyse, Strategie und Kreativitaet',
    detail: 'Fokus auf Projekte, bei denen Daten nicht nur korrekt, sondern auch richtungsgebend sein muessen.',
  },
  {
    label: 'Schwerpunkte',
    title: 'Forecasting, Produktanalyse, Experimentdesign und Data Storytelling',
    detail: 'Besonders spannend werden Projekte fuer mich dort, wo Unsicherheit, Ambiguitaet und Relevanz gleichzeitig hoch sind.',
  },
  {
    label: 'Interesse',
    title: 'Innovation, Struktur und eigenstaendige kreative Praxis',
    detail: 'Ich mag Arbeit, die gleichzeitig analytisch sauber, strategisch brauchbar und menschlich verstaendlich ist.',
  },
];

const entryPoints = [
  {
    kicker: 'AI & Data',
    title: 'Analytische Klarheit fuer Produkt, Innovation und Entscheidungen.',
    body: 'Wenn Daten, Modelle oder AI in eine belastbare Richtung uebersetzt werden sollen, ist das der richtige Einstieg.',
    href: '/beratung',
    cta: 'AI & Data ansehen',
  },
  {
    kicker: 'Musik',
    title: 'Ein eigener Raum fuer Klang, Rhythmus und kreative Arbeit.',
    body: 'Neben meiner analytischen Arbeit ist Musik ein eigenstaendiger Teil meiner Praxis und meines Denkens.',
    href: '/musik',
    cta: 'Musik ansehen',
  },
];

const externalLinks = [
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/raphael-fredebeul-733605140/',
  },
  {
    label: 'SoundCloud',
    href: 'https://soundcloud.com/raphael-fredebeul',
  },
];

const contactMailto =
  'mailto:?subject=Anfrage%20zu%20AI%20%26%20Data&body=Hallo%20Raphael,%0A%0Aich%20interessiere%20mich%20fuer%20deine%20Arbeit%20im%20Bereich%20AI%20%26%20Data.%0A%0AViele%20Gruesse';
---

<Layout
  title="Raphael Fredebeul | Data Scientist"
  description="Persoenliche Website von Raphael Fredebeul mit Fokus auf AI & Data, Innovation, Kreativitaet und Consulting."
>
  <main class="page" id="main-content">
    <SiteHeader current="home" />

    <section class="intro">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="kicker">Data Scientist</p>
          <h1>Daten, Strategie und kreative Praxis mit klarer Haltung.</h1>
          <p class="lead">
            Ich arbeite an Themen rund um Data Science, Innovation und analytische Orientierung.
            Diese Website ist als offene Uebersicht ueber meine Arbeit, meine Musik und meine Texte
            gedacht.
          </p>

          <div class="hero-actions">
            <a class="button button-primary" href={withBase('/beratung')}>AI & Data entdecken</a>
            <a class="button button-secondary" href={withBase('/musik')}>Musik ansehen</a>
          </div>

          <div class="tag-row" aria-label="Schwerpunkte">
            <span>Forecasting</span>
            <span>Produktfragen</span>
            <span>Innovation</span>
            <span>Kreative Praxis</span>
          </div>
        </div>

        <aside class="hero-panel" aria-label="Aktuelle Schwerpunkte">
          <div class="panel-head">
            <p class="panel-kicker">Aktuell im Fokus</p>
            <a class="mini-link" href={withBase('/beratung#artikel')}>Artikel ansehen</a>
          </div>

          <div class="focus-stack">
            {currentFocus.map((item) => (
              <article class="focus-card">
                <h2>{item.title}</h2>
                <p>{item.detail}</p>
              </article>
            ))}
          </div>

          <div class="hero-links">
            {externalLinks.map((item) => (
              <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
            ))}
          </div>
        </aside>
      </div>
    </section>

    <section class="section blog-preview">
      <div class="section-head">
        <div class="section-copy">
          <p class="kicker">AI & Data Artikel</p>
          <h2>Notizen und Artikel aus meiner analytischen Arbeit.</h2>
          <p class="section-text">
            Die letzten Beitraege geben einen schnellen Eindruck davon, wie ich ueber Daten,
            Unsicherheit, Experimente und Strukturierung nachdenke.
          </p>
        </div>
        <a class="section-link" href={withBase('/beratung#artikel')}>Alle Artikel</a>
      </div>

      <div class="post-grid">
        {blogPosts.map((post) => (
          <article class="post-card">
            <p class="meta">{post.data.publishDate.toLocaleDateString('de-DE', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}</p>
            <h3>
              <a href={withBase(`/blog/${post.slug}`)}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div class="section-copy">
          <p class="kicker">Arbeitsweise</p>
          <h2>Wie ich analytische Arbeit einordne.</h2>
          <p class="section-text">
            Mich interessieren Projekte, bei denen Daten helfen sollen, Orientierung herzustellen
            und nicht nur Aktivitaet zu dokumentieren.
          </p>
        </div>
      </div>

      <div class="principles-grid">
        {principles.map((item) => (
          <article class="surface-card principle-card">
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div class="section-copy">
          <p class="kicker">Bereiche</p>
          <h2>Zwei unterschiedliche Einstiege in dieselbe Arbeitsweise.</h2>
        </div>
      </div>

      <div class="feature-grid">
        {entryPoints.map((item) => (
          <article class="feature-card">
            <p class="kicker">{item.kicker}</p>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
            <a class="section-link" href={withBase(item.href)}>{item.cta}</a>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div class="section-copy">
          <p class="kicker">Kurzprofil</p>
          <h2>Ein kompakter Rahmen fuer die Art von Arbeit, die ich suche.</h2>
        </div>
      </div>

      <div class="profile-grid">
        {profileHighlights.map((item) => (
          <article class="surface-card profile-card">
            <p class="meta-label">{item.label}</p>
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="kontakt">
      <div class="contact-card">
        <div class="section-copy">
          <p class="kicker">Kontakt</p>
          <h2>Wenn du ueber ein Projekt oder eine Zusammenarbeit sprechen moechtest, freue ich mich ueber eine Nachricht.</h2>
          <p class="section-text">
            Fuer AI & Data kannst du mir direkt schreiben. Fuer Musik findest du unten und im
            Musikbereich die wichtigsten Plattformen.
          </p>
        </div>

        <div class="contact-actions">
          <a class="button button-primary" href={contactMailto}>AI & Data per E-Mail anfragen</a>
          <a class="button button-secondary" href="https://soundcloud.com/raphael-fredebeul" target="_blank" rel="noreferrer">
            SoundCloud
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page {
    width: var(--container);
    margin: 0 auto;
    padding: 1rem 0 4rem;
  }

  .intro,
  .section {
    border-top: 1px solid var(--line);
  }

  .intro {
    padding: 2rem 0 2.4rem;
  }

  .section {
    padding: 2.2rem 0;
  }

  .hero-grid,
  .contact-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.92fr);
    gap: clamp(1.4rem, 3vw, 3rem);
    align-items: start;
  }

  .kicker,
  .meta,
  .meta-label,
  .panel-kicker {
    margin: 0;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent-strong);
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin: 0.55rem 0 1rem;
    max-width: 11ch;
    font-size: var(--title-xl);
    line-height: 0.96;
    letter-spacing: -0.045em;
  }

  h2 {
    margin: 0.45rem 0 0;
    max-width: 15ch;
    font-size: var(--title-lg);
    line-height: 1.02;
    letter-spacing: -0.035em;
  }

  h3 {
    margin: 0;
    font-size: var(--title-md);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .lead,
  .section-text,
  .focus-card p,
  .surface-card p,
  .post-card p {
    color: var(--muted);
    line-height: 1.68;
    font-size: var(--text-md);
  }

  .lead {
    max-width: 40rem;
    font-size: var(--text-lg);
  }

  .hero-actions,
  .hero-links,
  .contact-actions,
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .hero-actions {
    margin-top: 2rem;
  }

  .tag-row {
    margin-top: 1.2rem;
  }

  .tag-row span {
    display: inline-flex;
    align-items: center;
    min-height: 2.5rem;
    padding: 0.65rem 0.9rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.48);
    color: var(--muted);
    font-size: 0.92rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    padding: 0.88rem 1.3rem;
    border: 1px solid var(--text);
    border-radius: var(--radius-pill);
  }

  .button-primary {
    background: var(--text);
    color: var(--bg);
    box-shadow: var(--shadow-card);
  }

  .button-secondary {
    background: transparent;
    color: var(--text);
  }

  .button:hover,
  .section-link:hover,
  .mini-link:hover,
  .post-card a:hover,
  .hero-links a:hover {
    color: var(--accent-strong);
    border-color: currentColor;
    transform: translateY(-1px);
  }

  .button-primary:hover {
    color: var(--bg);
    background: var(--accent-strong);
  }

  .hero-panel,
  .surface-card,
  .post-card,
  .feature-card,
  .contact-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: var(--panel);
    box-shadow: var(--shadow-card);
    backdrop-filter: blur(14px);
  }

  .hero-panel {
    padding: 1.2rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(244, 240, 232, 0.78)),
      var(--panel);
  }

  .panel-head,
  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
  }

  .section-copy {
    display: grid;
    gap: 0.2rem;
  }

  .mini-link,
  .section-link,
  .post-card a {
    color: var(--text);
  }

  .mini-link,
  .section-link {
    white-space: nowrap;
  }

  .focus-stack,
  .post-grid,
  .principles-grid,
  .feature-grid,
  .profile-grid {
    display: grid;
    gap: 1rem;
    margin-top: 1.4rem;
  }

  .focus-stack,
  .profile-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .post-grid,
  .principles-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .feature-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .focus-card,
  .surface-card,
  .post-card,
  .feature-card {
    padding: 1.25rem;
  }

  .focus-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.54);
  }

  .focus-card h2 {
    margin: 0;
    max-width: 100%;
    font-size: 1.36rem;
    line-height: 1.14;
  }

  .focus-card p,
  .surface-card p,
  .post-card p,
  .feature-card p {
    margin: 0.7rem 0 0;
  }

  .hero-links {
    margin-top: 1rem;
  }

  .hero-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.6rem;
    padding: 0.7rem 0.95rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    color: var(--text);
  }

  .section-text {
    margin-top: 0.8rem;
    max-width: 42rem;
  }

  .post-card {
    display: grid;
    align-content: start;
  }

  .post-card h3 {
    margin-top: 0.4rem;
  }

  .post-card:hover,
  .surface-card:hover,
  .feature-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-soft);
  }

  .feature-card {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(235, 238, 228, 0.78)),
      var(--panel);
  }

  .meta-label {
    margin-bottom: 0.8rem;
  }

  .contact-card {
    padding: 1.5rem;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(235, 238, 228, 0.74)),
      var(--panel);
  }

  .contact-actions {
    align-self: end;
    justify-content: flex-end;
  }

  @media (max-width: 1180px) {
    .hero-grid,
    .contact-card,
    .feature-grid,
    .profile-grid,
    .focus-stack {
      grid-template-columns: 1fr;
    }

    .contact-actions {
      align-self: start;
      justify-content: flex-start;
    }
  }

  @media (max-width: 1100px) {
    .post-grid,
    .principles-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 980px) {
    .post-grid,
    .principles-grid {
      grid-template-columns: 1fr;
    }

    .section-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .contact-actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 720px) {
    .page {
      padding-top: 0.7rem;
    }

    .intro {
      padding-top: 1.35rem;
    }

    .section,
    .intro {
      padding-bottom: 1.8rem;
    }

    h1,
    h2 {
      max-width: 100%;
    }

    .panel-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .hero-panel,
    .surface-card,
    .post-card,
    .feature-card,
    .contact-card {
      border-radius: var(--radius-lg);
    }

    .button,
    .hero-links a {
      width: 100%;
    }

    .tag-row span {
      width: 100%;
      justify-content: center;
    }
  }
</style>

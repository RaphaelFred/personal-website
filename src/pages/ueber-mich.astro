---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { withBase } from '../utils/paths';

const cvPoints = [
  'Data Scientist mit Fokus auf AI, Datenanalyse und Innovation.',
  'Arbeit an der Schnittstelle von analytischer Praezision, strategischer Einordnung und praktischer Umsetzbarkeit.',
  'Interesse an Projekten, in denen neue Technologien sinnvoll in reale Arbeitsprozesse uebersetzt werden.',
];

const serviceDetails = [
  {
    id: 'tool-exploration',
    title: 'Tool-Exploration',
    detail:
      'Ich unterstuetze dabei, geeignete Daten- und KI-Tools fuer konkrete Geschaefts- und Innovationsprozesse einzuordnen. Im Mittelpunkt steht eine Auswahl, die zu Aufgaben, Team und organisatorischem Reifegrad passt.',
  },
  {
    id: 'use-cases',
    title: 'Use Cases',
    detail:
      'Gemeinsam identifiziere ich Anwendungsfaelle, bei denen KI echten Mehrwert schaffen kann. Entscheidend sind dabei nicht nur Ideen, sondern Klarheit ueber Nutzen, Risiko, Priorisierung und die konkrete Umsetzung im Alltag.',
  },
  {
    id: 'ki-schulungen',
    title: 'KI-Schulungen',
    detail:
      'Ich entwickle Schulungen, die Mitarbeitenden einen praktischen und sicheren Zugang zu KI-Tools ermoeglichen. Ziel ist eine bessere Nutzung im Arbeitsalltag, nicht nur ein abstraktes Verstaendnis der Technologie.',
  },
  {
    id: 'datenanalysen',
    title: 'Datenanalysen',
    detail:
      'Ich fuehre Datenanalysen so durch, dass daraus konkrete Handlungsempfehlungen entstehen. Gute Analyse soll nicht nur Erkenntnisse liefern, sondern Entscheidungen, Prioritaeten und naechste Schritte belastbar machen.',
  },
];

const evidenceGroups = [
  {
    label: 'Praxis',
    title: 'Wirtschaft & Industrie',
    items: [
      {
        title: 'Miele',
        detail:
          'Daten- und AI-Fragestellungen in einem industriellen Kontext, in dem analytische Arbeit anschlussfaehig und praktisch nutzbar sein muss.',
      },
      {
        title: 'Arvato / Bertelsmann',
        detail:
          'Erfahrung mit datengetriebenen Themen in Konzern- und Organisationsumfeldern, in denen Analyse, Umsetzung und Kommunikation zusammenkommen.',
      },
    ],
  },
  {
    label: 'Forschung',
    title: 'Akademischer Hintergrund',
    items: [
      {
        title: 'Universitaet Bielefeld',
        detail: 'Analytische Ausbildung und wissenschaftliches Arbeiten als Grundlage fuer strukturierte Datenarbeit.',
      },
      {
        title: 'Nova Universidade',
        detail: 'Internationale Perspektive auf Technologie, Organisation und die Einordnung komplexer Fragestellungen.',
      },
    ],
  },
  {
    label: 'Wettbewerb',
    title: 'SORDI.ai',
    items: [
      {
        title: '4. Platz im AI Wettbewerb',
        detail: 'Teilnahme am SORDI.ai AI-Wettbewerb mit Platzierung unter den besten Einreichungen.',
      },
    ],
  },
];

const contactMailto =
  'mailto:raphaeldc@gmx.de?subject=Anfrage%20zu%20AI%20%26%20Data&body=Hallo%20Raphael,%0A%0Aich%20interessiere%20mich%20fuer%20deine%20Arbeit%20im%20Bereich%20AI%20%26%20Data.%0A%0AViele%20Gruesse';

const contactDestinations = [
  { label: 'AI & Data', href: '/beratung', icon: 'grid' },
  { label: 'Texte', href: '/blog', icon: 'pen' },
  { label: 'E-Mail', href: contactMailto, icon: 'mail' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/raphael-fredebeul-733605140/', icon: 'linkedin' },
  { label: 'SoundCloud', href: 'https://soundcloud.com/raphael-fredebeul', icon: 'soundcloud' },
];
---

<Layout
  title="Über Mich | Raphael Fredebeul"
  description="Über mich: Raphael Fredebeul über AI, Datenanalyse, Innovation und die Bereiche, in denen er Unternehmen unterstuetzt."
>
  <main class="page" id="main-content">
    <SiteHeader current="about" />

    <section class="intro-section" aria-label="Einleitung">
      <div class="intro-main">
        <p class="kicker">Raphael Fredebeul</p>
        <h1>Über <br>
          mich</h1>
      </div>
    </section>

    <section class="section" aria-label="Kurzprofil">
      <div class="profile-grid">
        <figure class="profile-image">
          <img
            src={withBase('/images/raphael-portrait.jpeg')}
            alt="Raphael Fredebeul draussen vor einer Kuestenlandschaft"
            loading="eager"
            decoding="async"
          />
        </figure>

        <div class="profile-copy">
          <div class="section-copy">
            <p class="kicker">Wofür ich stehe</p>
            <h2>Bessere Entscheidungen mit KI und Daten.</h2>
            <p class="section-text">
              Die eigentliche Frage ist nicht, ob wir KI nutzen. Die Frage ist, ob sie unser Denken besser macht.
              Ich verbinde Data Science, AI Enablement und strategische Problemklärung, um aus Komplexität klarere Fragen,
              bessere Entscheidungen und konkrete nächste Schritte zu entwickeln.
            </p>
          </div>

          <div class="cv-list">
            {cvPoints.map((item) => (
              <div class="cv-item">
                <p>{item}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section" aria-label="Stationen und Nachweise">
      <div class="evidence-section-grid">
        <div class="section-copy">
          <p class="kicker">Stationen & Nachweise</p>
          <h2>Kontexte, aus denen meine Arbeit kommt.</h2>
          <p class="section-text">
            Meine Perspektive entsteht aus praktischer Datenarbeit, akademischem Hintergrund
            und Wettbewerbserfahrung im AI-Umfeld.
          </p>
        </div>

        <div class="evidence-groups">
          {evidenceGroups.map((group) => (
            <section class="evidence-group" aria-label={group.title}>
              <div class="evidence-group-head">
                <p class="evidence-label">{group.label}</p>
                <h3>{group.title}</h3>
              </div>
              <div class="evidence-items">
                {group.items.map((item) => (
                  <article class="evidence-item">
                    <h4>{item.title}</h4>
                    <p>{item.detail}</p>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="was-ich-biete" aria-label="Was ich biete">
      <div class="section-grid">
        <div class="section-copy">
          <p class="kicker">Was ich biete</p>
          <h2>Vier Bereiche, in denen ich Unternehmen besonders konkret unterstuetze.</h2>
        </div>

        <div class="services-grid">
          {serviceDetails.map((item) => (
            <article class="service-card" id={item.id}>
              <h3>{item.title}</h3>
              <p>{item.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="contact-showcase" id="kontakt" aria-label="Kontakt">
      <div class="contact-hero">
        <div class="contact-card">
          <h2>Schreib mir gern.</h2>
          <p class="contact-copy">
             Wenn du über KI, Daten, Innovation oder eine konkrete Herausforderung sprechen möchtest, freue ich mich über eine Nachricht.
          </p>
          <a class="contact-mail-link" href={contactMailto}>Kontakt</a>
        </div>
      </div>

      <div class="contact-icons" aria-label="Bereiche und Profile">
        {contactDestinations.map((item) => (
          <a
            class="icon-tile"
            href={item.href}
            target={item.href.startsWith('http') ? '_blank' : undefined}
            rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
            aria-label={item.label}
            title={item.label}
          >
            {item.icon === 'grid' ? (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 4h7v7H4V4Zm9 0h7v7h-7V4ZM4 13h7v7H4v-7Zm9 0h7v7h-7v-7Z" />
              </svg>
            ) : item.icon === 'wave' ? (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M3 12c2.4 0 2.4-6 4.8-6s2.4 12 4.8 12S15 9 17.4 9 19.8 15 22 15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            ) : item.icon === 'pen' ? (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m4 16.5 9.9-9.9 3.5 3.5-9.9 9.9L4 20l.5-3.5ZM14.9 5.6l1.7-1.7a1.9 1.9 0 0 1 2.7 0l1 1a1.9 1.9 0 0 1 0 2.7l-1.7 1.7-3.7-3.7Z" />
              </svg>
            ) : item.icon === 'mail' ? (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 6h16v12H4V6Zm0 1.2 8 6 8-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            ) : item.icon === 'linkedin' ? (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6.94 8.5V19H3.5V8.5h3.44ZM7.16 5.26c0 1-.74 1.74-1.94 1.74A1.72 1.72 0 0 1 3.32 5.3c0-1 .76-1.76 1.92-1.76s1.88.74 1.92 1.72ZM20.68 12.58V19h-3.42v-6.02c0-1.52-.54-2.56-1.9-2.56-1.04 0-1.66.7-1.94 1.38-.1.24-.12.58-.12.92V19H9.88s.04-9.74 0-10.5h3.42v1.48c.45-.7 1.26-1.7 3.08-1.7 2.24 0 3.92 1.46 3.92 4.6Z" />
              </svg>
            ) : (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4.37 13.44a2.06 2.06 0 0 0 2.05 2.06h11.95a1.58 1.58 0 1 0 0-3.16h-.59a4.24 4.24 0 0 0-8.13-1.66 2.75 2.75 0 0 0-1.08-.22 2.73 2.73 0 0 0-2.63 1.97 2.05 2.05 0 0 0-1.57 2.01Zm14.72 4.1c.24 0 .43.19.43.42v.34a.43.43 0 0 1-.43.43H5.74a.43.43 0 0 1-.43-.43v-.34c0-.23.19-.42.43-.42h13.35Zm-11.4 2.15c.23 0 .42.19.42.42v.35a.42.42 0 0 1-.42.42H5.74a.42.42 0 0 1-.43-.42v-.35c0-.23.19-.42.43-.42h1.95Zm3.04 0c.23 0 .42.19.42.42v.35a.42.42 0 0 1-.42.42H8.78a.42.42 0 0 1-.42-.42v-.35c0-.23.19-.42.42-.42h1.95Zm3.03 0c.24 0 .43.19.43.42v.35a.43.43 0 0 1-.43.42h-1.95a.42.42 0 0 1-.42-.42v-.35c0-.23.19-.42.42-.42h1.95Zm3.03 0c.24 0 .43.19.43.42v.35a.43.43 0 0 1-.43.42h-1.95a.42.42 0 0 1-.42-.42v-.35c0-.23.19-.42.42-.42h1.95Z" />
              </svg>
            )}
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  .page {
    width: var(--page-container);
    margin: 0 auto;
    padding: 1rem 0 4rem;
  }

  .intro-section,
  .section,
  .contact-showcase {
    border-top: 1px solid var(--line);
  }

  .section {
    padding: 4.5rem 0;
    scroll-margin-top: 1.5rem;
  }

  .intro-section {
    position: relative;
    overflow: hidden;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    min-height: var(--hero-min-height);
    display: flex;
    align-items: start;
    padding: clamp(2.2rem, 5vw, 3rem) 0 2rem;
    border-bottom: 1px solid var(--line);
  }

  .intro-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(244, 246, 243, 0.04), rgba(244, 246, 243, 0.12)),
      url('/images/hero-illustration.jpg') center / cover no-repeat;
    opacity: 1;
    pointer-events: none;
    z-index: 0;
    filter: saturate(0.66) contrast(0.92);
  }

  .intro-section::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(244, 246, 243, 0.74) 0%, rgba(244, 246, 243, 0.34) 34%, rgba(244, 246, 243, 0.08) 100%),
      linear-gradient(180deg, rgba(244, 246, 243, 0.1) 0%, rgba(244, 246, 243, 0.02) 36%, rgba(244, 246, 243, 0.18) 100%);
    pointer-events: none;
    z-index: 0;
  }

  .intro-main {
    max-width: 40rem;
    width: var(--page-container);
    margin: 0 auto;
    position: relative;
    z-index: 1;
    padding-top: 0.2rem;
  }

  .section-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
  }

  .evidence-section-grid {
    display: grid;
    gap: clamp(1.6rem, 4vw, 3rem);
  }

  .evidence-section-grid .section-copy {
    max-width: 46rem;
  }

  .evidence-section-grid h2 {
    max-width: 16ch;
  }

  .profile-grid {
    display: grid;
    grid-template-columns: minmax(280px, 0.82fr) minmax(0, 1fr);
    gap: clamp(1.6rem, 5vw, 4rem);
    align-items: center;
  }

  .profile-copy {
    display: grid;
    gap: 1.4rem;
  }

  .profile-image {
    position: relative;
    overflow: hidden;
    margin: 0;
    min-height: 30rem;
    aspect-ratio: 4 / 5;
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: var(--panel);
    box-shadow: var(--shadow-card);
  }

  .profile-image::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(244, 246, 243, 0.02), rgba(23, 25, 20, 0.14)),
      linear-gradient(90deg, rgba(244, 246, 243, 0.16), transparent 42%);
  }

  .profile-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 36%;
    filter: saturate(0.9) contrast(0.96);
  }

  .kicker {
    margin: 0;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent-strong);
  }

  h1,
  h2,
  h3,
  h4,
  p {
    margin-top: 0;
  }

  h1 {
    margin: 0.55rem 0 0;
    max-width: 11ch;
    font-size: var(--title-xl);
    line-height: 0.96;
    letter-spacing: -0.045em;
  }

  h2 {
    margin: 0.45rem 0 0;
    max-width: 14ch;
    font-size: var(--title-lg);
    line-height: 1.02;
    letter-spacing: -0.035em;
  }

  h3 {
    margin: 0;
    font-size: var(--title-md);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .section-text,
  .cv-item p,
  .service-card p,
  .contact-copy {
    color: var(--muted);
    line-height: 1.7;
    font-size: var(--text-md);
  }

  .section-text {
    margin: 1rem 0 0;
    max-width: 34rem;
  }

  .cv-list,
  .services-grid {
    display: grid;
    gap: 1rem;
  }

  .cv-item,
  .service-card {
    padding: 1.2rem 1.25rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--panel);
    box-shadow: var(--shadow-card);
  }

  .evidence-groups {
    display: grid;
    gap: 0;
    border-top: 1px solid var(--line);
  }

  .evidence-group {
    display: grid;
    grid-template-columns: minmax(170px, 0.42fr) minmax(0, 1fr);
    gap: clamp(1.2rem, 3vw, 2.5rem);
    padding: 1.45rem 0;
    border-bottom: 1px solid var(--line);
  }

  .evidence-group-head {
    display: grid;
    align-content: start;
    gap: 0.4rem;
  }

  .evidence-label {
    margin: 0;
    color: var(--accent-strong);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    line-height: 1.15;
    text-transform: uppercase;
  }

  .evidence-group h3 {
    font-size: clamp(1.22rem, 1.8vw, 1.55rem);
    line-height: 1.08;
  }

  .evidence-items {
    display: grid;
    gap: 1.05rem;
  }

  .evidence-item {
    display: grid;
    gap: 0.45rem;
    max-width: 42rem;
  }

  .cv-item p,
  .service-card p {
    margin: 0.7rem 0 0;
  }

  .evidence-item h4 {
    margin: 0;
    font-size: clamp(1.02rem, 1.35vw, 1.2rem);
    line-height: 1.18;
  }

  .evidence-item p {
    margin: 0;
    color: var(--muted);
    font-size: 0.94rem;
    line-height: 1.58;
  }

  .contact-showcase {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    padding: 4.5rem 0 0;
  }

  .contact-hero {
    position: relative;
    overflow: hidden;
    min-height: 34rem;
    display: grid;
    place-items: center;
    padding: 2rem;
    background:
      linear-gradient(180deg, rgba(244, 246, 243, 0.18), rgba(244, 246, 243, 0.24)),
      url('/images/contact-illustration.jpg') center / cover no-repeat;
  }

  .contact-card {
    width: min(100%, 46rem);
    padding: clamp(2rem, 5vw, 4rem);
    background: rgba(248, 249, 246, 0.93);
    border: 1px solid rgba(23, 25, 20, 0.08);
    box-shadow: 0 20px 50px rgba(23, 25, 20, 0.08);
    text-align: center;
  }

  .contact-card h2 {
    margin-left: auto;
    margin-right: auto;
    max-width: 13ch;
  }

  .contact-copy {
    margin: 1rem auto 0;
    max-width: 30rem;
  }

  .contact-mail-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.7rem;
    margin-top: 2rem;
    padding: 0 1.5rem;
    border: 1px solid var(--text);
    background: var(--text);
    color: #fff;
    cursor: pointer;
    text-decoration: none;
  }

  .contact-mail-link:hover {
    background: var(--accent-strong);
    border-color: var(--accent-strong);
  }

  .contact-icons {
    width: var(--page-container);
    margin-left: auto;
    margin-right: auto;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.35rem;
    padding: 1.35rem 0 0;
    border-top: 1px solid var(--line);
  }

  .icon-tile {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--text);
  }

  .icon-tile svg {
    width: 1.15rem;
    height: 1.15rem;
    fill: currentColor;
  }

  .icon-tile:hover {
    color: var(--accent-strong);
    border-color: currentColor;
    transform: translateY(-1px);
  }

  @media (max-width: 900px) {
    .profile-grid,
    .section-grid {
      grid-template-columns: 1fr;
    }

    .profile-image {
      min-height: 0;
      max-height: 42rem;
      width: min(100%, 30rem);
    }

    .intro-section {
      min-height: var(--hero-min-height-mobile);
      align-items: start;
    }

    .intro-section::before {
      opacity: 1;
    }

    .intro-section::after {
      background: linear-gradient(180deg, rgba(244, 246, 243, 0.58) 0%, rgba(244, 246, 243, 0.24) 42%, rgba(244, 246, 243, 0.18) 100%);
    }

    .contact-mail-link {
      width: 100%;
    }
  }

  @media (max-width: 720px) {
    .page {
      padding-top: 0.6rem;
      padding-bottom: 3rem;
    }

    .intro-main {
      width: var(--page-container);
    }

    h1,
    h2 {
      max-width: 100%;
    }

    .intro-section {
      padding-top: 1.6rem;
    }

    .profile-image {
      width: 100%;
      aspect-ratio: 4 / 5;
      border-radius: var(--radius-lg);
    }

    .evidence-group {
      grid-template-columns: 1fr;
      gap: 0.85rem;
      padding: 1.25rem 0;
    }

    .evidence-group-head {
      gap: 0.25rem;
    }

    .contact-hero {
      min-height: 28rem;
      padding: 1rem;
    }

    .contact-icons {
      width: var(--page-container);
    }

    .contact-card {
      padding: 1.5rem;
    }
  }
</style>

---
import Layout from '../layouts/Layout.astro';

const expertise = [
  'Decision intelligence and KPI design',
  'Predictive modeling with explainable ML',
  'Experimentation, A/B testing, and causal analysis',
  'Data storytelling for executive and product teams',
];

const highlights = [
  { value: '12+', label: 'launches spanning analytics, ML, and experimentation' },
  { value: '34%', label: 'typical lift uncovered through better funnel insight' },
  { value: '< 2w', label: 'from vague business question to a board-ready narrative' },
];

const caseStudies = [
  {
    title: 'Churn Signals for a Subscription Product',
    tag: 'Behavioral Modeling',
    summary:
      'Combined usage telemetry, CRM history, and lifecycle events into an explainable risk model that gave growth teams a weekly retention playbook.',
  },
  {
    title: 'Marketing Mix Reframed for Incrementality',
    tag: 'Measurement Strategy',
    summary:
      'Moved a team from vanity channel attribution to decision-focused experimentation, making spend allocation easier to defend with finance and leadership.',
  },
  {
    title: 'Operations Forecasting for a High-Variance Pipeline',
    tag: 'Forecasting Systems',
    summary:
      'Designed a forecasting layer that paired confidence bands with scenario planning so operators could act on uncertainty instead of hiding it.',
  },
];

const principles = [
  'Editorial typography and asymmetrical composition for a more premium personal-brand feel.',
  'Glassmorphism used selectively, with strong contrast and clear hierarchy instead of soft generic cards.',
  'Data-native visuals like grids, traces, and metric callouts that reinforce the subject matter.',
  'Compact motion cues through hover, reveal, and layered gradients rather than distracting page noise.',
];
---

<Layout
  title="Avery Lane | Data Scientist"
  description="A premium Astro personal website for a data scientist brand focused on machine learning, experimentation, and strategic storytelling."
>
  <main class="page-shell">
    <div class="ambient ambient-left"></div>
    <div class="ambient ambient-right"></div>

    <header class="site-header">
      <div class="brand-lockup">
        <span class="brand-mark">AL</span>
        <div>
          <p class="eyebrow">Personal Brand</p>
          <p class="brand-name">Avery Lane, Data Scientist</p>
        </div>
      </div>
      <nav class="site-nav" aria-label="Main navigation">
        <a href="#work">Work</a>
        <a href="#approach">Approach</a>
        <a href="#writing">Writing</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Machine Learning • Analytics Strategy • Experimentation</p>
        <h1>Turning noisy data into decisive stories, better products, and measurable growth.</h1>
        <p class="hero-text">
          I help teams move from reporting to real decision systems. My work blends modeling,
          experimentation, and sharp communication so stakeholders know what matters, why it
          matters, and what to do next.
        </p>

        <div class="hero-actions">
          <a class="button button-primary" href="#contact">Book a collaboration call</a>
          <a class="button button-secondary" href="#work">See selected projects</a>
        </div>

        <div class="signal-strip" aria-label="Core focus areas">
          {expertise.map((item) => (
            <span>{item}</span>
          ))}
        </div>
      </div>

      <aside class="hero-panel">
        <div class="hero-card hero-card-top">
          <p class="card-label">Current Positioning</p>
          <h2>Data science for product, growth, and executive clarity.</h2>
          <p>
            Built for founders, operators, and product teams who need strong analytical judgment
            without sacrificing speed or readability.
          </p>
        </div>

        <div class="insight-grid">
          {highlights.map((item) => (
            <article class="stat-card">
              <p class="stat-value">{item.value}</p>
              <p class="stat-label">{item.label}</p>
            </article>
          ))}
        </div>

        <div class="hero-card hero-card-bottom">
          <div class="trace trace-one"></div>
          <div class="trace trace-two"></div>
          <p class="card-label">Signal Snapshot</p>
          <p class="microcopy">A modern personal site should feel human, credible, and visibly analytical at first glance.</p>
        </div>
      </aside>
    </section>

    <section class="section intro-grid" id="work">
      <div class="section-heading">
        <p class="eyebrow">Selected Work</p>
        <h2>Strategy-led case studies instead of portfolio filler.</h2>
      </div>
      <div class="case-study-grid">
        {caseStudies.map((study) => (
          <article class="case-card">
            <p class="tag">{study.tag}</p>
            <h3>{study.title}</h3>
            <p>{study.summary}</p>
            <a href="#contact">Discuss a similar engagement</a>
          </article>
        ))}
      </div>
    </section>

    <section class="section split-section" id="approach">
      <div class="section-heading">
        <p class="eyebrow">Approach</p>
        <h2>Built around the newest personal-site patterns, adapted for a data scientist.</h2>
      </div>
      <div class="split-layout">
        <article class="panel large-panel">
          <p class="panel-kicker">Design Specification</p>
          <ul class="principles-list">
            {principles.map((principle) => (
              <li>{principle}</li>
            ))}
          </ul>
        </article>

        <article class="panel timeline-panel">
          <p class="panel-kicker">Working Style</p>
          <div class="timeline">
            <div>
              <span>01</span>
              <p>Frame the business problem before choosing any model.</p>
            </div>
            <div>
              <span>02</span>
              <p>Build analytical systems that people can actually trust and use.</p>
            </div>
            <div>
              <span>03</span>
              <p>Translate outputs into narrative, action, and measurable next steps.</p>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section class="section writing-section" id="writing">
      <div class="section-heading">
        <p class="eyebrow">Writing and Speaking</p>
        <h2>Thought leadership that strengthens the brand beyond project delivery.</h2>
      </div>
      <div class="writing-grid">
        <article class="writing-card featured">
          <p class="tag">Featured Essay</p>
          <h3>What high-trust analytics looks like when the stakes are commercial, not academic.</h3>
          <p>
            A perspective on building models and dashboards that drive decisions because they are
            legible, grounded, and intentionally scoped.
          </p>
        </article>
        <article class="writing-card">
          <p class="tag">Talk</p>
          <h3>From dashboards to decisions</h3>
          <p>How to make executive reporting more actionable with fewer charts and better framing.</p>
        </article>
        <article class="writing-card">
          <p class="tag">Newsletter</p>
          <h3>Signals worth following</h3>
          <p>A digest on experimentation, growth analytics, and modern ML operating habits.</p>
        </article>
      </div>
    </section>

    <section class="section contact-section" id="contact">
      <div class="contact-panel">
        <div>
          <p class="eyebrow">Contact</p>
          <h2>Ready for a personal site that positions you like a strategic operator, not just a model builder?</h2>
        </div>
        <div class="contact-actions">
          <a class="button button-primary" href="mailto:avery@datalane.studio">avery@datalane.studio</a>
          <a class="button button-secondary" href="https://www.linkedin.com" target="_blank" rel="noreferrer">LinkedIn</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-shell {
    position: relative;
    width: var(--container);
    margin: 0 auto;
    padding: 1.25rem 0 4rem;
    overflow: clip;
  }

  .ambient {
    position: absolute;
    z-index: 0;
    filter: blur(50px);
    opacity: 0.7;
    pointer-events: none;
  }

  .ambient-left {
    top: 7rem;
    left: -6rem;
    width: 16rem;
    height: 16rem;
    background: rgba(67, 211, 255, 0.22);
  }

  .ambient-right {
    top: 18rem;
    right: -7rem;
    width: 18rem;
    height: 18rem;
    background: rgba(255, 212, 122, 0.18);
  }

  .site-header,
  .hero,
  .section,
  .contact-panel {
    position: relative;
    z-index: 1;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 0 2rem;
  }

  .brand-lockup {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border: 1px solid rgba(125, 249, 208, 0.32);
    border-radius: 50%;
    background: rgba(10, 20, 34, 0.8);
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .brand-name,
  .eyebrow {
    margin: 0;
  }

  .eyebrow {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.75rem;
  }

  .brand-name {
    margin-top: 0.25rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .site-nav a:hover,
  .case-card a:hover {
    color: var(--text);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 1.5rem;
    align-items: stretch;
    padding: 2rem 0 1rem;
  }

  .hero-copy,
  .hero-panel,
  .panel,
  .case-card,
  .writing-card,
  .contact-panel {
    border: 1px solid var(--line);
    background: var(--panel);
    backdrop-filter: blur(18px);
    box-shadow: var(--shadow);
  }

  .hero-copy {
    padding: clamp(1.5rem, 4vw, 3rem);
    border-radius: var(--radius-xl);
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 12ch;
    margin: 0.75rem 0 1.25rem;
    font-size: clamp(3.25rem, 9vw, 6.8rem);
    line-height: 0.92;
    letter-spacing: -0.05em;
  }

  .hero-text,
  .hero-card p,
  .case-card p,
  .writing-card p,
  .timeline p,
  .contact-panel p,
  .principles-list,
  .microcopy {
    color: var(--muted);
    line-height: 1.65;
    font-size: 1rem;
  }

  .hero-actions,
  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin: 2rem 0 2.25rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.25rem;
    padding: 0.8rem 1.25rem;
    border-radius: 999px;
    border: 1px solid transparent;
    font-weight: 600;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button-primary {
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-strong) 100%);
    color: #04111c;
  }

  .button-secondary {
    border-color: rgba(156, 193, 255, 0.2);
    background: rgba(5, 12, 24, 0.28);
  }

  .signal-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .signal-strip span,
  .tag,
  .card-label,
  .panel-kicker {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 0.45rem 0.8rem;
    border: 1px solid rgba(156, 193, 255, 0.18);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    color: #dbe8ff;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
  }

  .hero-panel {
    display: grid;
    gap: 1rem;
    padding: 1rem;
    border-radius: var(--radius-xl);
  }

  .hero-card,
  .stat-card,
  .panel,
  .case-card,
  .writing-card {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--panel-strong);
  }

  .hero-card,
  .panel,
  .case-card,
  .writing-card {
    padding: 1.4rem;
  }

  .hero-card h2,
  .section-heading h2,
  .contact-panel h2 {
    font-size: clamp(1.7rem, 3vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin-bottom: 0.9rem;
  }

  .insight-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .stat-card {
    padding: 1.2rem;
    border: 1px solid var(--line);
  }

  .stat-value {
    margin: 0 0 0.5rem;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--accent-warm);
  }

  .stat-label {
    margin: 0;
    color: var(--muted);
    line-height: 1.5;
  }

  .hero-card-bottom {
    min-height: 180px;
  }

  .trace {
    position: absolute;
    inset-inline: 1rem;
    height: 1px;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent 0%, rgba(125, 249, 208, 0.8) 35%, transparent 100%);
  }

  .trace-one {
    top: 46%;
    transform: rotate(-6deg);
  }

  .trace-two {
    top: 58%;
    background: linear-gradient(90deg, transparent 0%, rgba(67, 211, 255, 0.8) 35%, transparent 100%);
    transform: rotate(9deg);
  }

  .section {
    padding: 1.25rem 0;
  }

  .section-heading {
    display: grid;
    gap: 0.65rem;
    margin-bottom: 1.25rem;
  }

  .section-heading h2 {
    max-width: 14ch;
    margin: 0;
  }

  .case-study-grid,
  .writing-grid,
  .split-layout {
    display: grid;
    gap: 1rem;
  }

  .case-study-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .case-card h3,
  .writing-card h3 {
    margin-bottom: 0.85rem;
    font-size: 1.45rem;
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .case-card a {
    color: var(--accent);
    font-weight: 600;
  }

  .split-layout {
    grid-template-columns: 1.15fr 0.85fr;
  }

  .principles-list {
    margin: 1rem 0 0;
    padding-left: 1.2rem;
  }

  .principles-list li + li {
    margin-top: 0.8rem;
  }

  .timeline {
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }

  .timeline div {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: start;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(156, 193, 255, 0.12);
  }

  .timeline div:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .timeline span {
    color: var(--accent-warm);
    font-weight: 700;
    font-size: 1.1rem;
  }

  .writing-grid {
    grid-template-columns: 1.2fr 1fr 1fr;
  }

  .featured {
    background:
      linear-gradient(180deg, rgba(67, 211, 255, 0.08), transparent 55%),
      var(--panel-strong);
  }

  .contact-panel {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border-radius: var(--radius-xl);
  }

  @media (max-width: 1100px) {
    .hero,
    .case-study-grid,
    .split-layout,
    .writing-grid,
    .contact-panel {
      grid-template-columns: 1fr;
    }

    .contact-panel {
      display: grid;
      align-items: start;
    }
  }

  @media (max-width: 780px) {
    .site-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .site-nav,
    .insight-grid {
      width: 100%;
    }

    .insight-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      grid-template-columns: 1fr;
      padding-top: 1rem;
    }

    .hero-copy,
    .hero-panel,
    .panel,
    .case-card,
    .writing-card,
    .contact-panel {
      border-radius: 22px;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(2.8rem, 16vw, 4.2rem);
    }
  }
</style>

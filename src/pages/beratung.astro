---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import SiteHeader from '../components/SiteHeader.astro';
import { withBase } from '../utils/paths';

const offers = [
  {
    title: 'AI & Data',
    detail:
      'Unterstuetzung bei analytischen Fragestellungen, Modellierung, KPI-Systemen und datengetriebenen Entscheidungen.',
    points: ['Forecasting und Modelllogik', 'Exploration relevanter Signale', 'Pragmatische Datennutzung'],
  },
  {
    title: 'Produkt und Innovation',
    detail:
      'Analyse von Nutzerverhalten, Identifikation neuer Chancen und Strukturierung von Innovations- und Produktfragen.',
    points: ['Nutzer- und Produktverhalten', 'Hypothesen fuer neue Chancen', 'Priorisierung unter Unsicherheit'],
  },
  {
    title: 'Strategische Kommunikation',
    detail:
      'Insights so aufbereiten, dass Teams, Stakeholder und Entscheider damit wirklich arbeiten koennen.',
    points: ['Klare Entscheidungsbilder', 'Storylines fuer Stakeholder', 'Uebersetzung technischer Ergebnisse'],
  },
];

const collaborationCases = [
  {
    title: 'Viele Daten, wenig Richtung',
    detail: 'Wenn Signale vorhanden sind, aber noch keine klare Priorisierung oder belastbare Entscheidungslogik.',
  },
  {
    title: 'Ein Produktproblem braucht Struktur',
    detail: 'Wenn Teams zwischen Hypothesen, Datenlage und strategischem Druck eine klare analytische Form brauchen.',
  },
  {
    title: 'AI soll sinnvoll eingeordnet werden',
    detail: 'Wenn Potenziale sichtbar sind, aber Nutzen, Grenzen und naechste Schritte noch sauber geklaert werden muessen.',
  },
];

const process = [
  {
    title: 'Fragestellung schaerfen',
    detail: 'Gemeinsam klaeren wir, welche Entscheidung eigentlich vorbereitet werden soll und wo Unsicherheit herkommt.',
  },
  {
    title: 'Daten und Signale strukturieren',
    detail: 'Relevante Muster, Grenzen und blinde Flecken werden sichtbar gemacht, bevor Modelle zu frueh festgezurrt werden.',
  },
  {
    title: 'Hypothesen und Modelle entwickeln',
    detail: 'Analytische Loesungen werden so aufgebaut, dass sie belastbar und fuer das Team nachvollziehbar bleiben.',
  },
  {
    title: 'Ergebnisse in Handlung uebersetzen',
    detail: 'Am Ende steht keine Modellshow, sondern eine Richtung, mit der Produkt, Strategie oder Innovation weitergehen koennen.',
  },
];

const focusAreas = ['Forecasting', 'Produktanalyse', 'Experimentdesign', 'AI-Orientierung'];

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 4);

const contactMailto =
  'mailto:?subject=Anfrage%20zu%20AI%20%26%20Data&body=Hallo%20Raphael,%0A%0Aich%20interessiere%20mich%20fuer%20eine%20Zusammenarbeit%20im%20Bereich%20AI%20%26%20Data.%0A%0AViele%20Gruesse';
---

<Layout
  title="AI & Data | Raphael Fredebeul"
  description="AI & Data von Raphael Fredebeul fuer Innovation, Produktfragen und analytische Strategie."
>
  <main class="page" id="main-content">
    <SiteHeader current="ai-data" />

    <section class="hero">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="kicker">AI & Data</p>
          <h1>AI & Data fuer klare Entscheidungen, gute Modelle und belastbare Richtung.</h1>
          <p class="lead">
            Ich unterstuetze bei analytischen Fragestellungen rund um Produkt, Innovation,
            Forecasting und strategische Priorisierung.
          </p>

          <div class="hero-actions">
            <a class="button button-primary" href={contactMailto}>E-Mail schreiben</a>
            <a class="button button-secondary" href="#angebot">Leistungen ansehen</a>
          </div>

          <div class="tag-row" aria-label="Schwerpunkte">
            {focusAreas.map((item) => (
              <span>{item}</span>
            ))}
          </div>
        </div>

        <aside class="hero-side">
          <div class="graphic-panel" aria-label="Grafik">
            <img src={withBase('/graphics/ai-data-panel.svg')} alt="Abstrakte grafische Komposition fuer AI und Daten" />
          </div>

          <div class="hero-note">
            <p class="meta">Typische Situationen</p>
            <ul>
              <li>Ein Produktteam braucht eine belastbare Analyse statt mehr Dashboards.</li>
              <li>Eine datengetriebene Initiative muss strategisch eingeordnet werden.</li>
              <li>AI-Potenziale sollen konkret, realistisch und anschlussfaehig bewertet werden.</li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <section class="section" id="angebot">
      <div class="section-head">
        <div class="section-copy">
          <p class="kicker">Leistungsschwerpunkte</p>
          <h2>Wo ich besonders gerne unterstuetze.</h2>
          <p class="section-text">
            Der gemeinsame Nenner ist fast immer derselbe: Komplexitaet reduzieren, ohne wichtige
            Nuancen zu verlieren.
          </p>
        </div>
      </div>

      <div class="card-grid">
        {offers.map((item) => (
          <article class="card">
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
            <ul>
              {item.points.map((point) => (
                <li>{point}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div class="section-copy">
          <p class="kicker">Zusammenarbeit</p>
          <h2>In welchen Situationen diese Art von Arbeit besonders hilfreich wird.</h2>
        </div>
      </div>

      <div class="cases-grid">
        {collaborationCases.map((item) => (
          <article class="case-card">
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section split">
      <div class="section-copy">
        <p class="kicker">Arbeitsweise</p>
        <h2>Analytisch praezise, strategisch anschlussfaehig und offen fuer neue Perspektiven.</h2>
        <p class="section-text">
          Mir ist wichtig, dass analytische Tiefe nicht zu Distanz fuehrt. Die Arbeit soll fuer
          Teams greifbar bleiben und in Entscheidungen muenden.
        </p>
      </div>

      <div class="process-list">
        {process.map((item, index) => (
          <article class="process-item">
            <p class="step">{String(index + 1).padStart(2, '0')}</p>
            <div>
              <h3>{item.title}</h3>
              <p>{item.detail}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="artikel">
      <div class="section-head">
        <div class="section-copy">
          <p class="kicker">Artikel</p>
          <h2>Notizen, Analysen und Beispiele aus meiner Arbeit mit Daten und AI.</h2>
        </div>
        <a class="section-link" href={withBase('/blog')}>Zum Archiv</a>
      </div>

      <div class="article-grid">
        {posts.map((post) => (
          <article class="article-card">
            <p class="meta">
              {post.data.publishDate.toLocaleDateString('de-DE', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </p>
            <h3>
              <a href={withBase(`/blog/${post.slug}`)}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="kontakt">
      <div class="contact-card">
        <div class="section-copy">
          <p class="kicker">Kontakt</p>
          <h2>Wenn du ueber ein Projekt oder eine Zusammenarbeit sprechen moechtest, freue ich mich ueber eine Nachricht.</h2>
          <p class="section-text">
            Ich mag Projekte mit echter Entscheidungsrelevanz, offenem Denkraum und einem klaren
            Willen zu guter analytischer Arbeit.
          </p>
        </div>

        <div class="contact-links">
          <a class="button button-primary" href={contactMailto}>AI & Data per E-Mail anfragen</a>
          <a class="button button-secondary" href="#artikel">Artikel ansehen</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page {
    width: var(--container);
    margin: 0 auto;
    padding: 1.1rem 0 4rem;
  }

  .hero,
  .section {
    border-top: 1px solid var(--line);
  }

  .hero,
  .section {
    padding: 2rem 0;
  }

  .hero-grid,
  .contact-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.95fr);
    gap: clamp(1.4rem, 3vw, 3rem);
    align-items: start;
  }

  .hero-copy {
    padding-top: 0.35rem;
  }

  .hero-side {
    display: grid;
    gap: 1rem;
  }

  .kicker,
  .meta,
  .step {
    margin: 0;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent-strong);
  }

  h1,
  h2,
  h3,
  p,
  ul {
    margin-top: 0;
  }

  h1 {
    margin: 0.5rem 0 1rem;
    max-width: 11ch;
    font-size: var(--title-xl);
    line-height: 0.96;
    letter-spacing: -0.045em;
  }

  h2 {
    margin: 0.55rem 0 0;
    max-width: 15ch;
    font-size: var(--title-lg);
    line-height: 1.02;
    letter-spacing: -0.035em;
  }

  h3 {
    margin: 0;
    font-size: var(--title-md);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .lead,
  .section-text,
  .card p,
  .card li,
  .case-card p,
  .process-item p,
  .article-card p,
  .hero-note li {
    color: var(--muted);
    line-height: 1.68;
    font-size: var(--text-md);
  }

  .lead {
    max-width: 38rem;
    font-size: var(--text-lg);
  }

  .hero-actions,
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .hero-actions {
    margin-top: 2rem;
  }

  .tag-row {
    margin-top: 1.15rem;
  }

  .tag-row span {
    display: inline-flex;
    align-items: center;
    min-height: 2.5rem;
    padding: 0.65rem 0.9rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.48);
    color: var(--muted);
  }

  .button,
  .section-link {
    color: var(--text);
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    padding: 0.88rem 1.3rem;
    border: 1px solid var(--text);
    border-radius: var(--radius-pill);
  }

  .button-primary {
    background: var(--text);
    color: var(--bg);
    box-shadow: var(--shadow-card);
  }

  .button-secondary {
    background: transparent;
  }

  .button:hover,
  .section-link:hover,
  .article-card a:hover {
    color: var(--accent-strong);
    border-color: currentColor;
    transform: translateY(-1px);
  }

  .button-primary:hover {
    color: var(--bg);
    background: var(--accent-strong);
  }

  .graphic-panel img,
  .hero-note,
  .card,
  .case-card,
  .process-item,
  .article-card,
  .contact-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: var(--panel);
    box-shadow: var(--shadow-card);
  }

  .graphic-panel img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    background: white;
  }

  .hero-note,
  .card,
  .case-card,
  .process-item,
  .article-card,
  .contact-card {
    padding: 1.25rem;
  }

  .hero-note {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(244, 240, 232, 0.75)),
      var(--panel);
  }

  .hero-note ul,
  .card ul {
    padding-left: 1.1rem;
    margin-bottom: 0;
  }

  .hero-note li + li,
  .card li + li {
    margin-top: 0.55rem;
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .section-copy {
    display: grid;
    gap: 0.2rem;
  }

  .section-text {
    margin-top: 0.8rem;
    max-width: 42rem;
  }

  .card-grid,
  .cases-grid,
  .article-grid {
    display: grid;
    gap: 1rem;
  }

  .card-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .cases-grid,
  .article-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .card:hover,
  .case-card:hover,
  .article-card:hover,
  .process-item:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-soft);
  }

  .card p,
  .case-card p,
  .article-card p,
  .process-item p {
    margin: 0.7rem 0 0;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 2rem;
    align-items: start;
  }

  .process-list {
    display: grid;
    gap: 1rem;
  }

  .process-item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
  }

  .contact-card {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(235, 238, 228, 0.74)),
      var(--panel);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
    align-self: end;
  }

  @media (max-width: 1180px) {
    .hero-grid,
    .contact-card {
      grid-template-columns: 1fr;
    }

    .contact-links {
      align-items: flex-start;
      align-self: start;
    }
  }

  @media (max-width: 1100px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 980px) {
    .split,
    .cases-grid,
    .article-grid {
      grid-template-columns: 1fr;
    }

    .section-head {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 720px) {
    h1,
    h2 {
      max-width: 100%;
    }

    .hero,
    .section {
      padding: 1.7rem 0;
    }

    .button {
      width: 100%;
    }

    .tag-row span {
      width: 100%;
      justify-content: center;
    }

    .graphic-panel img,
    .hero-note,
    .card,
    .case-card,
    .process-item,
    .article-card,
    .contact-card {
      border-radius: var(--radius-lg);
    }
  }
</style>

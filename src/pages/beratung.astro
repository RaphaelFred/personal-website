---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import SiteHeader from '../components/SiteHeader.astro';
import { withBase } from '../utils/paths';

const offers = [
  {
    title: 'AI & Data',
    detail:
      'Unterstuetzung bei analytischen Fragestellungen, Modellierung, KPI-Systemen und datengetriebenen Entscheidungen.',
  },
  {
    title: 'Produkt und Innovation',
    detail:
      'Analyse von Nutzerverhalten, Identifikation neuer Chancen und Strukturierung von Innovations- und Produktfragen.',
  },
  {
    title: 'Strategische Kommunikation',
    detail:
      'Insights so aufbereiten, dass Teams, Stakeholder und Entscheider damit wirklich arbeiten koennen.',
  },
];

const process = [
  'Fragestellung schaerfen',
  'Daten und Signale strukturieren',
  'Hypothesen und Modelle entwickeln',
  'Ergebnisse in klare Handlungsschritte uebersetzen',
];

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 4);

const contactMailto =
  'mailto:?subject=Anfrage%20zu%20AI%20%26%20Data&body=Hallo%20Raphael,%0A%0Aich%20interessiere%20mich%20fuer%20eine%20Zusammenarbeit%20im%20Bereich%20AI%20%26%20Data.%0A%0AViele%20Gruesse';
---

<Layout
  title="AI & Data | Raphael Fredebeul"
  description="AI & Data von Raphael Fredebeul fuer Innovation, Produktfragen und analytische Strategie."
>
  <main class="page" id="main-content">
    <SiteHeader current="ai-data" />

    <section class="hero">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="kicker">AI & Data</p>
          <h1>AI & Data fuer klare Entscheidungen, gute Modelle und belastbare Richtung.</h1>
          <p class="lead">
            Ich unterstuetze bei analytischen Fragestellungen rund um Produkt, Innovation, Forecasting
            und strategische Priorisierung.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href={contactMailto}>E-Mail schreiben</a>
            <a class="button button-secondary" href="#angebot">Leistungen ansehen</a>
          </div>
        </div>
        <aside class="graphic-panel" aria-label="Grafik">
          <img src={withBase('/graphics/ai-data-panel.svg')} alt="Abstrakte grafische Komposition fuer AI und Daten" />
        </aside>
      </div>
    </section>

    <section class="section" id="angebot">
      <div class="section-intro">
        <p class="kicker">Leistungsschwerpunkte</p>
        <h2>Wo ich besonders gerne unterstuetze.</h2>
      </div>
      <div class="card-grid">
        {offers.map((item) => (
          <article class="card">
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section split">
      <div class="section-intro">
        <p class="kicker">Arbeitsweise</p>
        <h2>Analytisch praezise, strategisch anschlussfaehig und offen fuer neue Perspektiven.</h2>
      </div>
      <div class="process-list">
        {process.map((item, index) => (
          <article class="process-item">
            <p class="step">{String(index + 1).padStart(2, '0')}</p>
            <p>{item}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="artikel">
      <div class="section-header">
        <div class="section-intro">
          <p class="kicker">Artikel</p>
          <h2>Notizen, Analysen und Beispiele aus meiner Arbeit mit Daten und AI.</h2>
        </div>
        <a class="section-link" href={withBase('/blog')}>Zum Archiv</a>
      </div>
      <div class="article-grid">
        {posts.map((post) => (
          <article class="card article-card">
            <p class="meta">
              {post.data.publishDate.toLocaleDateString('de-DE', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </p>
            <h3>
              <a href={withBase(`/blog/${post.slug}`)}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="contact" id="kontakt">
      <div class="section-intro">
        <p class="kicker">Kontakt</p>
        <h2>Wenn du ueber ein Projekt oder eine Zusammenarbeit sprechen moechtest, freue ich mich ueber eine Nachricht.</h2>
      </div>
      <div class="contact-links">
        <a class="contact-primary" href={contactMailto}>AI & Data per E-Mail anfragen</a>
        <a href="#artikel">Artikel ansehen</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page {
    width: var(--container);
    margin: 0 auto;
    padding: 1.15rem 0 4rem;
  }

  .hero,
  .section,
  .contact {
    border-top: 1px solid var(--line);
  }

  .hero,
  .section,
  .contact {
    padding: 2rem 0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr);
    gap: 3.25rem;
    align-items: start;
  }

  .hero-copy {
    padding-top: 0.25rem;
  }

  .kicker,
  .step {
    margin: 0;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent-strong);
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin: 0.5rem 0 1rem;
    max-width: 11ch;
    font-size: var(--title-xl);
    line-height: 0.96;
    letter-spacing: -0.045em;
  }

  h2 {
    margin: 0.5rem 0 0;
    max-width: 15ch;
    font-size: var(--title-lg);
    line-height: 1.02;
    letter-spacing: -0.035em;
  }

  h3 {
    margin: 0 0 0.75rem;
    font-size: var(--title-md);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .lead,
  .card p,
  .process-item p,
  .contact-links a {
    color: var(--muted);
    line-height: 1.65;
    font-size: var(--text-md);
  }

  .lead {
    max-width: 38rem;
    font-size: var(--text-lg);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    padding: 0.85rem 1.35rem;
    border: 1px solid var(--text);
    border-radius: 999px;
  }

  .button-primary {
    background: var(--text);
    color: var(--bg);
  }

  .button-secondary {
    color: var(--text);
  }

  .graphic-panel img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border: 1px solid var(--line);
    background: white;
  }

  .section-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .section-intro {
    margin-bottom: 1.5rem;
  }

  .section-header .section-intro {
    margin-bottom: 0;
  }

  .section-link {
    color: var(--text);
    white-space: nowrap;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .card,
  .process-item {
    padding: 1.5rem;
    border: 1px solid var(--text);
    background: rgba(255, 255, 255, 0.78);
  }

  .article-card {
    display: grid;
    align-content: start;
    gap: 0.5rem;
  }

  .article-card h3 {
    margin-bottom: 0;
  }

  .article-card a,
  .section-link:hover {
    color: var(--text);
  }

  .article-card a:hover {
    color: var(--accent-strong);
  }

  .meta {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--accent-strong);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 2rem;
    align-items: start;
  }

  .process-list {
    display: grid;
    gap: 1rem;
  }

  .contact {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
  }

  .contact-primary {
    color: var(--text);
    font-weight: 600;
  }

  @media (max-width: 980px) {
    .hero-grid,
    .card-grid,
    .article-grid,
    .split,
    .contact {
      grid-template-columns: 1fr;
    }

    .section-header {
      align-items: start;
      flex-direction: column;
    }

    .contact {
      align-items: start;
    }

    .contact-links {
      align-items: flex-start;
    }
  }

  @media (max-width: 720px) {
    h1,
    h2 {
      max-width: 100%;
    }
  }
</style>

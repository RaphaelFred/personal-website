---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import SiteHeader from '../components/SiteHeader.astro';
import { withBase } from '../utils/paths';

const blogImages = {
  'building-clarity-from-complexity': {
    src: '/blog/ai-adoption-organisationen.jpg',
    alt: 'Abstrakte Szene zu AI Adoption in Organisationen',
  },
  'fruehe-produktsignale-erkennen': {
    src: '/blog/user-innovation-mit-ki.jpg',
    alt: 'Abstrakte Visualisierung zu User Innovation mit KI',
  },
  'experimente-richtig-framen': {
    src: '/blog/use-case-identifikation-ki.jpg',
    alt: 'Abstrakte Visualisierung zur Identifikation von KI-Use-Cases',
  },
  'forecasting-unter-unsicherheit': {
    src: '/blog/strategische-datenanalyse-innovation.jpg',
    alt: 'Abstrakte Visualisierung zu strategischer Datenanalyse und Unsicherheit',
  },
};

const offers = [
  {
    title: 'AI & Data',
    detail:
      'Unterstuetzung bei analytischen Fragestellungen, Modellierung, KPI-Systemen und datengetriebenen Entscheidungen.',
    points: ['Forecasting und Modelllogik', 'Exploration relevanter Signale', 'Pragmatische Datennutzung'],
  },
  {
    title: 'Produkt und Innovation',
    detail:
      'Analyse von Nutzerverhalten, Identifikation neuer Chancen und Strukturierung von Innovations- und Produktfragen.',
    points: ['Nutzer- und Produktverhalten', 'Hypothesen fuer neue Chancen', 'Priorisierung unter Unsicherheit'],
  },
  {
    title: 'Strategische Kommunikation',
    detail:
      'Insights so aufbereiten, dass Teams, Stakeholder und Entscheider damit wirklich arbeiten koennen.',
    points: ['Klare Entscheidungsbilder', 'Storylines fuer Stakeholder', 'Uebersetzung technischer Ergebnisse'],
  },
];

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const contactMailto =
  'mailto:raphaeldc@gmx.de?subject=Anfrage%20zu%20AI%20%26%20Data&body=Hallo%20Raphael,%0A%0Aich%20interessiere%20mich%20fuer%20eine%20Zusammenarbeit%20im%20Bereich%20AI%20%26%20Data.%0A%0AViele%20Gruesse';

const contactDestinations = [
  { label: 'AI & Data', href: '/beratung', icon: 'grid' },
  { label: 'Texte', href: '/blog', icon: 'pen' },
  { label: 'E-Mail', href: contactMailto, icon: 'mail' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/raphael-fredebeul-733605140/', icon: 'linkedin' },
  { label: 'SoundCloud', href: 'https://soundcloud.com/raphael-fredebeul', icon: 'soundcloud' },
];
---

<Layout
  title="AI & Data | Raphael Fredebeul"
  description="AI & Data von Raphael Fredebeul fuer Innovation, Produktfragen und analytische Strategie."
>
  <main class="page" id="main-content">
    <SiteHeader current="ai-data" />

    <section class="hero">
      <div class="intro-main">
        <p class="kicker">Raphael Fredebeul</p>
        <h1>AI & <br>
          Data<br>
  </h1>
      </div>
    </section>

    <section class="section" id="angebot">
      <div class="section-head">
        <div class="section-copy">
          <p class="kicker">Leistungsschwerpunkte</p>
          <h2>Wo ich besonders gerne unterstuetze.</h2>
          <p class="section-text">
            Der gemeinsame Nenner ist fast immer derselbe: Komplexitaet reduzieren, ohne wichtige
            Nuancen zu verlieren.
          </p>
        </div>
      </div>

      <div class="card-grid">
        {offers.map((item) => (
          <article class="card">
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
            <ul>
              {item.points.map((point) => (
                <li>{point}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="artikel">
      <div class="section-head">
        <div class="section-copy">
          <p class="kicker">Artikel</p>
          <h2>Notizen, Analysen und Beispiele aus meiner Arbeit mit Daten und AI.</h2>
        </div>
        <a class="section-link" href={withBase('/blog')}>Zum Archiv</a>
      </div>

      <div class="article-grid">
        {posts.map((post) => (
          <article class="article-card">
            <a class="article-image-link" href={withBase(`/blog/${post.slug}`)}>
              <img
                src={withBase(blogImages[post.slug]?.src ?? '/graphics/blog-panel.svg')}
                alt={blogImages[post.slug]?.alt ?? post.data.title}
                loading="lazy"
              />
            </a>
            <div class="article-copy">
              <p class="meta">
                {post.data.publishDate.toLocaleDateString('de-DE', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>
              <h3>
                <a href={withBase(`/blog/${post.slug}`)}>{post.data.title}</a>
              </h3>
              <p>{post.data.description}</p>
              <a class="article-link" href={withBase(`/blog/${post.slug}`)}>Artikel lesen</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="contact-showcase" id="kontakt" aria-label="Kontakt">
      <div class="contact-hero">
        <div class="contact-card">
          <h2>Schreib mir gern.</h2>
          <p class="contact-copy">
            Wenn du ueber ein Projekt, eine Zusammenarbeit oder eine konkrete Fragestellung
            sprechen moechtest, oeffnet sich per Klick direkt dein Mailprogramm.
          </p>
          <a class="contact-mail-link" href={contactMailto}>Kontakt</a>
        </div>
      </div>

      <div class="contact-icons" aria-label="Bereiche und Profile">
        {contactDestinations.map((item) => (
          <a
            class="icon-tile"
            href={item.href}
            target={item.href.startsWith('http') ? '_blank' : undefined}
            rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
            aria-label={item.label}
            title={item.label}
          >
            {item.icon === 'grid' ? (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 4h7v7H4V4Zm9 0h7v7h-7V4ZM4 13h7v7H4v-7Zm9 0h7v7h-7v-7Z" />
              </svg>
            ) : item.icon === 'pen' ? (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m4 16.5 9.9-9.9 3.5 3.5-9.9 9.9L4 20l.5-3.5ZM14.9 5.6l1.7-1.7a1.9 1.9 0 0 1 2.7 0l1 1a1.9 1.9 0 0 1 0 2.7l-1.7 1.7-3.7-3.7Z" />
              </svg>
            ) : item.icon === 'mail' ? (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 6h16v12H4V6Zm0 1.2 8 6 8-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            ) : item.icon === 'linkedin' ? (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6.94 8.5V19H3.5V8.5h3.44ZM7.16 5.26c0 1-.74 1.74-1.94 1.74A1.72 1.72 0 0 1 3.32 5.3c0-1 .76-1.76 1.92-1.76s1.88.74 1.92 1.72ZM20.68 12.58V19h-3.42v-6.02c0-1.52-.54-2.56-1.9-2.56-1.04 0-1.66.7-1.94 1.38-.1.24-.12.58-.12.92V19H9.88s.04-9.74 0-10.5h3.42v1.48c.45-.7 1.26-1.7 3.08-1.7 2.24 0 3.92 1.46 3.92 4.6Z" />
              </svg>
            ) : (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4.37 13.44a2.06 2.06 0 0 0 2.05 2.06h11.95a1.58 1.58 0 1 0 0-3.16h-.59a4.24 4.24 0 0 0-8.13-1.66 2.75 2.75 0 0 0-1.08-.22 2.73 2.73 0 0 0-2.63 1.97 2.05 2.05 0 0 0-1.57 2.01Zm14.72 4.1c.24 0 .43.19.43.42v.34a.43.43 0 0 1-.43.43H5.74a.43.43 0 0 1-.43-.43v-.34c0-.23.19-.42.43-.42h13.35Zm-11.4 2.15c.23 0 .42.19.42.42v.35a.42.42 0 0 1-.42.42H5.74a.42.42 0 0 1-.43-.42v-.35c0-.23.19-.42.43-.42h1.95Zm3.04 0c.23 0 .42.19.42.42v.35a.42.42 0 0 1-.42.42H8.78a.42.42 0 0 1-.42-.42v-.35c0-.23.19-.42.42-.42h1.95Zm3.03 0c.24 0 .43.19.43.42v.35a.43.43 0 0 1-.43.42h-1.95a.42.42 0 0 1-.42-.42v-.35c0-.23.19-.42.42-.42h1.95Zm3.03 0c.24 0 .43.19.43.42v.35a.43.43 0 0 1-.43.42h-1.95a.42.42 0 0 1-.42-.42v-.35c0-.23.19-.42.42-.42h1.95Z" />
              </svg>
            )}
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  .page {
    width: var(--container);
    margin: 0 auto;
    padding: 1.1rem 0 4rem;
  }

  .hero,
  .section,
  .contact-showcase {
    border-top: 1px solid var(--line);
  }

  .section {
    padding: 2rem 0;
  }

  .hero {
    position: relative;
    overflow: hidden;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    min-height: var(--hero-min-height);
    display: flex;
    align-items: start;
    padding: clamp(2.2rem, 5vw, 3rem) 0 2rem;
    border-bottom: 1px solid var(--line);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(244, 246, 243, 0.04), rgba(244, 246, 243, 0.12)),
      url('/images/hero-illustration.jpg') center / cover no-repeat;
    opacity: 1;
    pointer-events: none;
    z-index: 0;
    filter: saturate(0.66) contrast(0.92);
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(244, 246, 243, 0.74) 0%, rgba(244, 246, 243, 0.34) 34%, rgba(244, 246, 243, 0.08) 100%),
      linear-gradient(180deg, rgba(244, 246, 243, 0.1) 0%, rgba(244, 246, 243, 0.02) 36%, rgba(244, 246, 243, 0.18) 100%);
    pointer-events: none;
    z-index: 0;
  }

  .intro-main {
    max-width: 40rem;
    width: min(1120px, calc(100vw - 3rem));
    margin: 0 auto;
    position: relative;
    z-index: 1;
    padding-top: 0.2rem;
  }

  .kicker,
  .meta {
    margin: 0;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent-strong);
  }

  h1,
  h2,
  h3,
  p,
  ul {
    margin-top: 0;
  }

  h1 {
    margin: 0;
    max-width: 11ch;
    font-size: clamp(3.3rem, 8.5vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.055em;
  }

  h2 {
    margin: 0.55rem 0 0;
    max-width: 15ch;
    font-size: var(--title-lg);
    line-height: 1.02;
    letter-spacing: -0.035em;
  }

  h3 {
    margin: 0;
    font-size: var(--title-md);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .section-text,
  .card p,
  .card li,
  .article-card p {
    color: var(--muted);
    line-height: 1.68;
    font-size: var(--text-md);
  }

  .button,
  .section-link {
    color: var(--text);
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    padding: 0.88rem 1.3rem;
    border: 1px solid var(--text);
    border-radius: var(--radius-pill);
  }

  .button-primary {
    background: var(--text);
    color: var(--bg);
    box-shadow: var(--shadow-card);
  }

  .button-secondary {
    background: transparent;
  }

  .button:hover,
  .section-link:hover,
  .article-copy h3 a:hover,
  .article-link:hover {
    color: var(--accent-strong);
    border-color: currentColor;
    transform: translateY(-1px);
  }

  .button-primary:hover {
    color: var(--bg);
    background: var(--accent-strong);
  }

  .card,
  .article-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: var(--panel);
    box-shadow: var(--shadow-card);
  }

  .card,
  .article-card {
    padding: 1.25rem;
  }

  .card ul {
    padding-left: 1.1rem;
    margin-bottom: 0;
  }

  .card li + li {
    margin-top: 0.55rem;
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .section-copy {
    display: grid;
    gap: 0.2rem;
  }

  .section-text {
    margin-top: 0.8rem;
    max-width: 42rem;
  }

  .card-grid,
  .article-grid {
    display: grid;
    gap: 1rem;
  }

  .card-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .article-grid {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .card:hover,
  .article-card:hover,
  .article-image-link:hover img {
    transform: translateY(-3px);
    box-shadow: var(--shadow-soft);
  }

  .card p,
  .article-card p {
    margin: 0.7rem 0 0;
  }

  .article-card {
    display: grid;
    grid-template-columns: minmax(260px, 0.9fr) minmax(0, 1.1fr);
    gap: 1.4rem;
    align-items: start;
  }

  .article-image-link {
    display: block;
  }

  .article-image-link img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border: 1px solid var(--line);
    border-radius: calc(var(--radius-xl) - 0.35rem);
    background: rgba(255, 255, 255, 0.7);
  }

  .article-copy {
    display: grid;
    align-content: start;
  }

  .article-link {
    display: inline-flex;
    align-items: center;
    margin-top: 1.1rem;
    color: var(--text);
  }

  .article-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-soft);
  }

  .contact-showcase {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    padding: 4.5rem 0 0;
  }

  .contact-hero {
    position: relative;
    overflow: hidden;
    min-height: 34rem;
    display: grid;
    place-items: center;
    padding: 2rem;
    background:
      linear-gradient(180deg, rgba(244, 246, 243, 0.18), rgba(244, 246, 243, 0.24)),
      url('/images/contact-illustration.jpg') center / cover no-repeat;
  }

  .contact-card {
    width: min(100%, 46rem);
    padding: clamp(2rem, 5vw, 4rem);
    background: rgba(248, 249, 246, 0.93);
    border: 1px solid rgba(23, 25, 20, 0.08);
    box-shadow: 0 20px 50px rgba(23, 25, 20, 0.08);
    text-align: center;
  }

  .contact-card h2 {
    margin-left: auto;
    margin-right: auto;
    max-width: 13ch;
  }

  .contact-copy {
    margin: 1rem auto 0;
    max-width: 30rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .contact-mail-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.7rem;
    margin-top: 2rem;
    padding: 0 1.5rem;
    border: 1px solid var(--text);
    background: var(--text);
    color: #fff;
    cursor: pointer;
    text-decoration: none;
  }

  .contact-mail-link:hover {
    background: var(--accent-strong);
    border-color: var(--accent-strong);
  }

  .contact-icons {
    width: min(1120px, calc(100vw - 3rem));
    margin-left: auto;
    margin-right: auto;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.35rem;
    padding: 1.35rem 0 0;
    border-top: 1px solid var(--line);
  }

  .icon-tile {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--text);
  }

  .icon-tile svg {
    width: 1.15rem;
    height: 1.15rem;
    fill: currentColor;
  }

  .icon-tile:hover {
    color: var(--accent-strong);
    border-color: currentColor;
    transform: translateY(-1px);
  }

  @media (max-width: 1180px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 980px) {
    .article-grid {
      grid-template-columns: 1fr;
    }

    .article-card {
      grid-template-columns: 1fr;
    }

    .section-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .hero::after {
      background: linear-gradient(180deg, rgba(244, 246, 243, 0.84) 0%, rgba(244, 246, 243, 0.72) 56%, rgba(244, 246, 243, 0.46) 100%);
    }
  }

  @media (max-width: 720px) {
    h1,
    h2 {
      max-width: 100%;
    }

    .intro-main {
      width: min(1120px, calc(100vw - 1.5rem));
    }

    .section {
      padding: 1.7rem 0;
    }

    .hero {
      min-height: var(--hero-min-height-mobile);
      padding-top: 1.6rem;
    }

    .button {
      width: 100%;
    }

    .contact-mail-link {
      width: 100%;
    }

    .card,
    .article-card {
      border-radius: var(--radius-lg);
    }
  }

  @media (max-width: 720px) {
    .contact-hero {
      min-height: 28rem;
      padding: 1rem;
    }

    .contact-icons {
      width: min(1120px, calc(100vw - 1.5rem));
    }

    .contact-card {
      padding: 1.5rem;
      border-radius: var(--radius-lg);
    }
  }
</style>

---
import { withBase } from '../utils/paths';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Raphael Fredebeul | Data Science',
  description = 'Persoenliche Website von Raphael Fredebeul mit Fokus auf AI & Data, Innovation, Kreativitaet und Consulting.',
} = Astro.props;

const socialImage = withBase('/social-card.svg');
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" href={withBase('/favicon.ico')} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f8f5" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Raphael Fredebeul" />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href={withBase('/#main-content')}>Zum Inhalt springen</a>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f5f5ef;
    --bg-soft: #ebeee4;
    --bg-elevated: rgba(255, 255, 255, 0.76);
    --panel: rgba(255, 255, 255, 0.74);
    --panel-strong: rgba(255, 255, 255, 0.9);
    --panel-tint: rgba(244, 240, 232, 0.78);
    --line: rgba(23, 25, 20, 0.09);
    --line-strong: rgba(23, 25, 20, 0.18);
    --text: #171914;
    --muted: #596056;
    --accent: #b65a3a;
    --accent-strong: #8c3d22;
    --accent-warm: #cfaa71;
    --accent-cool: #7b9484;
    --shadow-soft: 0 22px 60px rgba(23, 25, 20, 0.08);
    --shadow-card: 0 14px 36px rgba(23, 25, 20, 0.07);
    --radius-2xl: 36px;
    --radius-xl: 28px;
    --radius-lg: 22px;
    --radius-md: 16px;
    --radius-pill: 999px;
    --container: min(1220px, calc(100vw - 1.5rem));
    --container-narrow: min(860px, calc(100vw - 1.5rem));
    --font-sans: "Avenir Next", "Segoe UI", "Helvetica Neue", sans-serif;
    --font-display: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
    --text-sm: 0.95rem;
    --text-md: 1rem;
    --text-lg: 1.08rem;
    --title-xl: clamp(3.35rem, 8vw, 6.25rem);
    --title-lg: clamp(2.15rem, 4.3vw, 3.6rem);
    --title-md: clamp(1.3rem, 2vw, 1.56rem);
  }

  * {
    box-sizing: border-box;
  }

  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    position: relative;
    isolation: isolate;
    margin: 0;
    min-width: 320px;
    min-height: 100vh;
    font-family: var(--font-sans);
    color: var(--text);
    background:
      radial-gradient(circle at top left, rgba(182, 90, 58, 0.12), transparent 26%),
      radial-gradient(circle at 85% 10%, rgba(207, 170, 113, 0.13), transparent 18%),
      radial-gradient(circle at 50% 80%, rgba(123, 148, 132, 0.09), transparent 24%),
      linear-gradient(180deg, #fafaf6 0%, #f5f5ef 46%, #eef1e8 100%);
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 12% 18%, rgba(255, 255, 255, 0.52), transparent 18%),
      radial-gradient(circle at 82% 22%, rgba(255, 255, 255, 0.34), transparent 16%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a,
  button,
  iframe {
    transition:
      color 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  a:focus-visible,
  button:focus-visible,
  iframe:focus-visible {
    outline: 2px solid var(--accent-strong);
    outline-offset: 3px;
  }

  .skip-link {
    position: absolute;
    left: 1rem;
    top: 1rem;
    z-index: 1000;
    padding: 0.75rem 1rem;
    border: 1px solid var(--text);
    border-radius: 999px;
    background: #ffffff;
    transform: translateY(-200%);
    transition: transform 180ms ease;
  }

  .skip-link:focus-visible {
    transform: translateY(0);
  }

  img {
    max-width: 100%;
    display: block;
  }

  main,
  section,
  article,
  aside,
  div,
  nav,
  header {
    min-width: 0;
  }

  h1,
  h2,
  h3 {
    font-family: var(--font-display);
    font-weight: 600;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }

  p,
  li {
    text-wrap: pretty;
    overflow-wrap: anywhere;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  ::selection {
    background: rgba(182, 90, 58, 0.18);
  }

  @media (max-width: 720px) {
    :root {
      --container: min(1220px, calc(100vw - 1rem));
      --container-narrow: min(860px, calc(100vw - 1rem));
      --title-xl: clamp(2.55rem, 12vw, 4rem);
      --title-lg: clamp(1.85rem, 7.5vw, 2.8rem);
      --title-md: clamp(1.18rem, 4.8vw, 1.4rem);
    }
  }
</style>
